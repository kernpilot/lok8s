#!/usr/bin/env bash
# examples/test — provision, verify, and tear down an example end to end.
#
#   examples/test lo      # local kind cluster (free)
#   examples/test capi    # Hetzner via Cluster API   (needs .secrets/hetzner.env; REAL infra)
#   examples/test kkp     # Hetzner via Kubermatic KKP (needs a KKP endpoint + tokens)
#
# Runs the example as its own lok8s project (PATH_BASE) against the repo's
# framework + toolchain (PATH_LOK8S / .bin / .kustomize). Credentials come from
# the example's gitignored .secrets/ — never from the repo or the environment.
#
# Cloud drivers need a registered SSH key. Rather than depend on a pre-existing
# one, this harness generates a THROWAWAY keypair in setup, registers it under
# the name the spec references, and deletes it again on teardown (even on
# failure) — so a run leaves nothing behind in the Hetzner account.
set -euo pipefail

name="${1:?usage: examples/test <lo|capi|kkp>}"
here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo="$(cd "${here}/.." && pwd)"
proj="${here}/${name}"
[[ -d "${proj}/clusters" ]] || { echo "examples/test: no example '${name}' at ${proj}" >&2; exit 1; }

# lok8s env (no direnv in CI): the example is the project; the framework + the
# built toolchain/plugins are reused from the repo.
export PATH_BASE="${proj}"
export PATH_BIN="${repo}/.bin"
export PATH_LOK8S="${repo}/.lok8s"
export PATH_CLUSTERS="${proj}/clusters"
export PATH_SECRETS="${proj}/.secrets"
export KUSTOMIZE_PLUGIN_HOME="${repo}/.kustomize"
export PATH="${PATH_BIN}:${PATH_LOK8S}:${PATH}"

domain="$(cd "${PATH_CLUSTERS}" && for d in */; do echo "${d%/}"; break; done)"
spec="${PATH_CLUSTERS}/${domain}/cluster.lok8s.yaml"
cluster="$(yq -r '.metadata.name' "${spec}")"

# Cloud credentials (only present for capi/kkp), from the gitignored .secrets.
[[ -f "${PATH_SECRETS}/hetzner.env" ]] && { set -a; . "${PATH_SECRETS}/hetzner.env"; set +a; }
if [[ "${name}" != "lo" && -z "${HCLOUD_TOKEN:-}" ]]; then
  echo "examples/test: ${name} needs HCLOUD_TOKEN — put it in ${PATH_SECRETS}/hetzner.env (gitignored)" >&2
  exit 2
fi

# The secrets plugin must exist (registry TLS + secret generators).
secret_bin="${KUSTOMIZE_PLUGIN_HOME}/secrets.lok8s.dev/v1/secret/Secret"
[[ -x "${secret_bin}" ]] || make -C "${repo}/kustomize" build BIN_ROOT="${KUSTOMIZE_PLUGIN_HOME}" >/dev/null

# kapply's progress UI writes to /dev/tty, so wrap provisioning in a PTY for
# headless runs (see FRICTION.md / GOLIVE-TODO 0.2).
run() { script -qec "$*" /dev/null; }

# ── teardown (runs on every exit: success, failure, or interrupt) ─────────
ssh_key_name="" ssh_key_file="" torn_down=0
teardown() {
  local rc=$?
  set +e
  [[ "${torn_down}" == 1 ]] && return "${rc}"
  torn_down=1

  echo ":: [${name}] tearing down"
  run "lo down" || true

  if [[ -n "${ssh_key_name}" ]]; then
    echo ":: [${name}] removing throwaway SSH key '${ssh_key_name}'"
    hcloud ssh-key delete "${ssh_key_name}" >/dev/null 2>&1 || true
  fi
  [[ -n "${ssh_key_file}" ]] && rm -f "${ssh_key_file}" "${ssh_key_file}.pub"

  # Cost guard: never leave billed servers behind. CAPH names them "<cluster>-*".
  if [[ "${name}" != "lo" && -n "${HCLOUD_TOKEN:-}" ]]; then
    local left
    left="$(hcloud server list -o noheader 2>/dev/null | awk -v p="${cluster}-" 'index($2,p)==1' | wc -l | tr -d ' ')"
    [[ "${left}" == 0 ]] || echo ":: [${name}] WARNING: ${left} Hetzner server(s) matching '${cluster}-*' still present — run 'hcloud server list'"
  fi
  return "${rc}"
}
trap teardown EXIT

# ── setup: throwaway SSH key for cloud drivers ────────────────────────────
if [[ "${name}" != "lo" ]]; then
  ssh_key_name="$(yq -r '.spec.provider.config.sshKeyName // .spec.hcloud.sshKeyName // ""' "${spec}")"
  if [[ -n "${ssh_key_name}" ]]; then
    ssh_key_file="$(mktemp -u "${TMPDIR:-/tmp}/lok8s-example-key.XXXXXX")"
    ssh-keygen -q -t ed25519 -N "" -C "lok8s-example throwaway" -f "${ssh_key_file}"
    echo ":: [${name}] registering throwaway SSH key '${ssh_key_name}'"
    hcloud ssh-key delete "${ssh_key_name}" >/dev/null 2>&1 || true   # idempotent re-runs
    hcloud ssh-key create --name "${ssh_key_name}" --public-key-from-file "${ssh_key_file}.pub" >/dev/null
  fi
fi

# ── provision ─────────────────────────────────────────────────────────────
echo ":: [${name}] provisioning ${domain} (cluster ${cluster})"
lo use "${domain}"
run "lo provision"

# ── verify ──────────────────────────────────────────────────────────────────
echo ":: [${name}] verifying"
kubeconfig="${PATH_BASE}/.kubeconfig/${cluster}.yaml"
[[ -f "${kubeconfig}" ]] || kubeconfig="${PATH_BASE}/.kubeconfig/${domain}.yaml"
export KUBECONFIG="${kubeconfig}"
# Expected Ready nodes = control-plane + worker replicas (cloud drivers); kind
# has no such fields, so expect at least 1. Requiring the FULL count keeps a
# broken/never-joining worker pool from passing green — a "≥1 Ready" gate goes
# green as soon as the control plane registers, masking a dead worker pool.
expected=$(yq -r '.spec.controlPlane.replicas // 0' "${spec}" 2>/dev/null)
[[ "${expected}" =~ ^[0-9]+$ ]] || expected=0
while IFS= read -r _r; do [[ "${_r}" =~ ^[0-9]+$ ]] && expected=$((expected + _r)); done \
  < <(yq -r '.spec.workers[].replicas // 1' "${spec}" 2>/dev/null)
(( expected >= 1 )) || expected=1
# Cloud nodes install Kubernetes via cloud-init, so this can take several minutes.
echo ":: [${name}] waiting for ${expected} node(s) Ready"
ready=0
for _ in $(seq 1 72); do
  ready=$(kubectl get nodes --no-headers 2>/dev/null | awk '$2=="Ready"' | wc -l | tr -d ' ')
  (( ready >= expected )) && break
  sleep 10
done
(( ready >= expected )) || { echo ":: [${name}] FAILED — ${ready}/${expected} nodes Ready"; kubectl get nodes 2>/dev/null || true; exit 1; }
kubectl get nodes

teardown
echo ":: [${name}] OK"
