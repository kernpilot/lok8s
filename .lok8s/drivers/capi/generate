#!/usr/bin/env argsh
# shellcheck shell=bash disable=SC2034
# capi — CAPI resource generation and management
# Detects provider from cluster spec, generates CAPI resources from templates,
# manages credential Secrets, and polls cluster readiness.

import utils/verbose
import utils/template

# Detect the CAPI provider from cluster spec fields.
# Usage: capi::detect_provider <cluster_yaml>
# Delegates to provider::detect from utils/provider.
capi::detect_provider() {
  provider::detect "$1"
}

# Generate CAPI resources from templates using values from cluster spec.
# Usage: capi::generate <cluster_yaml> <provider>
# Outputs multi-document YAML to stdout.
#
# Templates are modelled on CAPH v1.1.7's hcloud "ubuntu" flavor (v1beta2 CAPI
# core + v1beta1 CAPH, kubeadm stack installed on a stock image via cloud-init).
# Substitution uses an explicit envsubst whitelist so the cloud-init's own shell
# variables ($ARCH, $RUNC, $CONTAINERD, $KUBERNETES_VERSION, …) pass through
# untouched — only the lok8s template vars below are expanded.
capi::generate() {
  local cluster_yaml="$1" provider="$2"
  local tmpl_dir="${PATH_LOK8S}/drivers/capi/cluster"
  local core="${tmpl_dir}/core" prov="${tmpl_dir}/providers/hetzner"

  if [[ "${provider}" != "hetzner" ]]; then
    error "CAPI provider '${provider}' is not supported yet (only 'hetzner')."
    return 1
  fi

  # Cluster identity + Kubernetes version (full, trimmed, and minor — the
  # cloud-init needs the trimmed/minor forms for the apt repo + package pins).
  export CLUSTER_NAME CLUSTER_NAMESPACE CLUSTER_DOMAIN
  export K8S_VERSION K8S_VERSION_TRIMMED K8S_VERSION_MINOR
  export CP_REPLICAS CP_TYPE CREDENTIAL_SECRET_NAME
  export HCLOUD_REGION HCLOUD_SSH_KEY_NAME HCLOUD_IMAGE_NAME
  CLUSTER_NAME=$(yq -r '.metadata.name' "${cluster_yaml}")
  CLUSTER_NAMESPACE=$(yq -r '.spec.cluster.namespace // "default"' "${cluster_yaml}")
  CLUSTER_DOMAIN=$(yq -r '.spec.cluster.domain' "${cluster_yaml}")
  K8S_VERSION=$(yq -r '.spec.kubernetes.version' "${cluster_yaml}")
  K8S_VERSION_TRIMMED="${K8S_VERSION#v}"        # v1.31.12 -> 1.31.12
  K8S_VERSION_MINOR="${K8S_VERSION_TRIMMED%.*}" # 1.31.12  -> 1.31
  CP_REPLICAS=$(yq -r '.spec.controlPlane.replicas // 1' "${cluster_yaml}")
  CP_TYPE=$(yq -r '.spec.controlPlane.type // "cax11"' "${cluster_yaml}")
  CREDENTIAL_SECRET_NAME=$(yq -r '.spec.credentials.secretName // .spec.provider.credentials.secretRef // (.metadata.name + "-credentials")' "${cluster_yaml}")
  HCLOUD_REGION=$(yq -r '.spec.provider.config.region // .spec.hcloud.region // "fsn1"' "${cluster_yaml}")
  HCLOUD_SSH_KEY_NAME=$(yq -r '.spec.provider.config.sshKeyName // .spec.hcloud.sshKeyName // ""' "${cluster_yaml}")
  HCLOUD_IMAGE_NAME=$(yq -r '.spec.provider.config.image // "ubuntu-24.04"' "${cluster_yaml}")

  if [[ -z "${HCLOUD_SSH_KEY_NAME}" ]]; then
    error "spec.provider.config.sshKeyName is required for the hetzner CAPI provider"
    return 1
  fi

  # Only these are expanded; everything else (cloud-init shell vars) is literal.
  # shellcheck disable=SC2016  # a literal ${VAR} list is exactly what envsubst wants
  local wl='${CLUSTER_NAME} ${CLUSTER_NAMESPACE} ${CLUSTER_DOMAIN} ${K8S_VERSION} ${K8S_VERSION_TRIMMED} ${K8S_VERSION_MINOR} ${CP_REPLICAS} ${CP_TYPE} ${HCLOUD_REGION} ${HCLOUD_SSH_KEY_NAME} ${HCLOUD_IMAGE_NAME} ${CREDENTIAL_SECRET_NAME} ${POOL_NAME} ${POOL_REPLICAS} ${POOL_TYPE}'

  # Cluster-scoped resources (Cluster, HetznerCluster, KCP, CP machine template).
  local first=1 d
  for d in \
    "${core}/cluster.yaml" \
    "${prov}/hetzner-cluster.yaml" \
    "${core}/kubeadm-control-plane.yaml" \
    "${prov}/hcloud-machine-template-controlplane.yaml"; do
    (( first )) || echo "---"; first=0
    envsubst "${wl}" < "${d}"
  done

  # One MachineDeployment + KubeadmConfigTemplate + worker machine template per pool.
  export POOL_NAME POOL_REPLICAS POOL_TYPE
  local pool
  for pool in $(yq -r '.spec.workers | keys[]?' "${cluster_yaml}"); do
    POOL_NAME="${pool}"
    POOL_REPLICAS=$(yq -r ".spec.workers.${pool}.replicas // 1" "${cluster_yaml}")
    POOL_TYPE=$(yq -r ".spec.workers.${pool}.type // \"cax11\"" "${cluster_yaml}")
    for d in \
      "${core}/machine-deployment.yaml" \
      "${prov}/kubeadm-config-template.yaml" \
      "${prov}/hcloud-machine-template-worker.yaml"; do
      echo "---"
      envsubst "${wl}" < "${d}"
    done
  done
}

# Create or update the provider credential Secret on the management cluster.
# Usage: capi::ensure_credentials <cluster_yaml> <provider> <kubeconfig>
capi::ensure_credentials() {
  local cluster_yaml="$1" provider="$2" kubeconfig="$3"
  local secret_name namespace
  secret_name=$(yq -r '.spec.credentials.secretName // .spec.provider.credentials.secretRef // (.metadata.name + "-credentials")' "${cluster_yaml}")
  namespace=$(yq -r '.spec.cluster.namespace // "default"' "${cluster_yaml}")

  credentials::require "${provider}" || return 1

  case "${provider}" in
    hetzner)
      kubectl create secret generic "${secret_name}" \
        --namespace "${namespace}" \
        --kubeconfig "${kubeconfig}" \
        --from-literal=hcloud-token="${HCLOUD_TOKEN}" \
        --from-literal=robot-user="${HROBOT_USER:-}" \
        --from-literal=robot-password="${HROBOT_PASSWORD:-}" \
        --dry-run=client -o yaml | kubectl apply --kubeconfig "${kubeconfig}" -f -
      ;;
    aws)
      : "${AWS_REGION:?AWS_REGION required for AWS provider}"
      kubectl create secret generic "${secret_name}" \
        --namespace "${namespace}" \
        --kubeconfig "${kubeconfig}" \
        --from-literal=access-key-id="${AWS_ACCESS_KEY_ID}" \
        --from-literal=secret-access-key="${AWS_SECRET_ACCESS_KEY}" \
        --from-literal=region="${AWS_REGION}" \
        --dry-run=client -o yaml | kubectl apply --kubeconfig "${kubeconfig}" -f -
      ;;
    *)
      error "Unsupported provider for credentials: ${provider}"
      return 1
      ;;
  esac
}

# Wait for a CAPI cluster to become ready.
# Usage: capi::wait_ready <kubeconfig> <cluster_name> [namespace] [timeout_seconds]
capi::wait_ready() {
  local kubeconfig="$1" cluster_name="$2" namespace="${3:-default}" timeout="${4:-600}"
  local elapsed=0 interval=10

  debug "Waiting for CAPI cluster ${cluster_name} to become ready (timeout: ${timeout}s)"

  while (( elapsed < timeout )); do
    local phase
    phase=$(kubectl get cluster "${cluster_name}" \
      --namespace "${namespace}" \
      --kubeconfig "${kubeconfig}" \
      -o jsonpath='{.status.phase}' 2>/dev/null || echo "")

    if [[ "${phase}" == "Provisioned" ]]; then
      debug "Cluster ${cluster_name} is Provisioned"
      return 0
    fi

    debug "Cluster ${cluster_name} phase: ${phase:-Unknown} (${elapsed}/${timeout}s)"
    sleep "${interval}"
    elapsed=$(( elapsed + interval ))
  done

  error "Timed out waiting for cluster ${cluster_name} (${timeout}s)"
  return 1
}
