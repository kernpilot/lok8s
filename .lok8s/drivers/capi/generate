#!/usr/bin/env argsh
# shellcheck shell=bash disable=SC2034
# capi — CAPI resource generation and management
# Detects provider from cluster spec, generates CAPI resources from templates,
# manages credential Secrets, and polls cluster readiness.

import utils/verbose
import utils/template

# Detect the CAPI provider from cluster spec fields.
# Usage: capi::detect_provider <cluster_yaml>
# Delegates to provider::detect from utils/provider.
capi::detect_provider() {
  provider::detect "$1"
}

# Generate CAPI resources from templates using values from cluster spec.
# Usage: capi::generate <cluster_yaml> <provider>
# Outputs multi-document YAML to stdout.
capi::generate() {
  local cluster_yaml="$1" provider="$2"
  local tmpl_dir="${PATH_LOK8S}/drivers/capi/cluster"

  if [[ ! -d "${tmpl_dir}" ]]; then
    error "CAPI template directory not found: ${tmpl_dir}"
    return 1
  fi

  # Extract variables from cluster.lok8s.yaml
  export CLUSTER_NAME CLUSTER_NAMESPACE CLUSTER_DOMAIN K8S_VERSION
  export CP_REPLICAS CREDENTIAL_SECRET_NAME
  CLUSTER_NAME=$(yq -r '.metadata.name' "${cluster_yaml}")
  CLUSTER_NAMESPACE=$(yq -r '.spec.cluster.namespace // "default"' "${cluster_yaml}")
  CLUSTER_DOMAIN=$(yq -r '.spec.cluster.domain' "${cluster_yaml}")
  K8S_VERSION=$(yq -r '.spec.kubernetes.version' "${cluster_yaml}")
  CP_REPLICAS=$(yq -r '.spec.controlPlane.replicas // 1' "${cluster_yaml}")
  CREDENTIAL_SECRET_NAME=$(yq -r '.spec.credentials.secretName // (.metadata.name + "-credentials")' "${cluster_yaml}")

  # Provider-specific variables
  case "${provider}" in
    hetzner)
      export INFRA_API_VERSION="infrastructure.cluster.x-k8s.io/v1beta1"
      export INFRA_CLUSTER_KIND="HetznerCluster"
      export INFRA_MACHINE_TEMPLATE_KIND="HCloudMachineTemplate"
      export HCLOUD_REGION HCLOUD_SSH_KEY_NAME
      HCLOUD_REGION=$(yq -r '.spec.hcloud.region' "${cluster_yaml}")
      HCLOUD_SSH_KEY_NAME=$(yq -r '.spec.hcloud.sshKeyName' "${cluster_yaml}")
      ;;
    aws)
      export INFRA_API_VERSION="infrastructure.cluster.x-k8s.io/v1beta2"
      export INFRA_CLUSTER_KIND="AWSCluster"
      export INFRA_MACHINE_TEMPLATE_KIND="AWSMachineTemplate"
      export AWS_REGION AWS_SSH_KEY_NAME AWS_INSTANCE_TYPE
      AWS_REGION=$(yq -r '.spec.aws.region' "${cluster_yaml}")
      AWS_SSH_KEY_NAME=$(yq -r '.spec.aws.sshKeyName // ""' "${cluster_yaml}")
      AWS_INSTANCE_TYPE=$(yq -r '.spec.controlPlane.type // "t3.medium"' "${cluster_yaml}")
      ;;
    *)
      error "Unsupported CAPI provider: ${provider}"
      return 1
      ;;
  esac

  # Render core templates
  local first=1
  for tmpl in "${tmpl_dir}/core"/*.yaml; do
    [[ -f "${tmpl}" ]] || continue
    if (( first )); then
      first=0
    else
      echo "---"
    fi
    envsubst < "${tmpl}"
  done

  # Render provider templates. Skip hrobot-* here — those are rendered
  # per-host later, only if spec.hrobot.hosts is configured.
  local provider_dir="${tmpl_dir}/providers/${provider}"
  if [[ -d "${provider_dir}" ]]; then
    for tmpl in "${provider_dir}"/*.yaml; do
      [[ -f "${tmpl}" ]] || continue
      case "$(basename "${tmpl}")" in
        hrobot-*) continue ;;
      esac
      echo "---"
      envsubst < "${tmpl}"
    done
  fi

  # Render worker pool machine deployments
  local pool
  for pool in $(yq -r '.spec.workers | keys[]?' "${cluster_yaml}"); do
    export POOL_NAME="${pool}"
    export POOL_REPLICAS POOL_TYPE MACHINE_TEMPLATE_NAME
    POOL_REPLICAS=$(yq -r ".spec.workers.${pool}.replicas // 1" "${cluster_yaml}")
    POOL_TYPE=$(yq -r ".spec.workers.${pool}.type" "${cluster_yaml}")
    MACHINE_TEMPLATE_NAME="${CLUSTER_NAME}-${pool}"
    echo "---"
    envsubst < "${tmpl_dir}/core/machine-deployment.yaml"

    # Render provider-specific worker machine template
    case "${provider}" in
      hetzner)
        if [[ -f "${provider_dir}/hcloud-machine-template.yaml" ]]; then
          export MACHINE_TYPE="${POOL_TYPE}"
          export MACHINE_IMAGE_NAME
          MACHINE_IMAGE_NAME=$(yq -r ".spec.workers.${pool}.imageName // \"ubuntu-22.04\"" "${cluster_yaml}")
          echo "---"
          envsubst < "${provider_dir}/hcloud-machine-template.yaml"
        fi
        ;;
      aws)
        if [[ -f "${provider_dir}/aws-machine-template.yaml" ]]; then
          export AWS_INSTANCE_TYPE="${POOL_TYPE}"
          echo "---"
          envsubst < "${provider_dir}/aws-machine-template.yaml"
        fi
        ;;
    esac
  done

  # Conditional: render hrobot bare metal templates when spec.hrobot.hosts is configured
  if [[ "${provider}" == "hetzner" ]] && yq -e '.spec.hrobot.hosts' "${cluster_yaml}" &>/dev/null; then
    local host
    for host in $(yq -r '.spec.hrobot.hosts[].name' "${cluster_yaml}"); do
      export HOST_NAME="${host}"
      export HOST_SERVER_NUMBER ROOT_DEVICE_WWN MACHINE_TEMPLATE_NAME
      HOST_SERVER_NUMBER=$(yq -r ".spec.hrobot.hosts[] | select(.name == \"${host}\") | .serverNumber" "${cluster_yaml}")
      ROOT_DEVICE_WWN=$(yq -r ".spec.hrobot.hosts[] | select(.name == \"${host}\") | .rootDeviceHints.wwn // \"\"" "${cluster_yaml}")
      MACHINE_TEMPLATE_NAME="${CLUSTER_NAME}-${host}"
      if [[ -f "${provider_dir}/hrobot-machine-template.yaml" ]]; then
        echo "---"
        envsubst < "${provider_dir}/hrobot-machine-template.yaml"
      fi
    done
  fi
}

# Create or update the provider credential Secret on the management cluster.
# Usage: capi::ensure_credentials <cluster_yaml> <provider> <kubeconfig>
capi::ensure_credentials() {
  local cluster_yaml="$1" provider="$2" kubeconfig="$3"
  local secret_name namespace
  secret_name=$(yq -r '.spec.credentials.secretName // (.metadata.name + "-credentials")' "${cluster_yaml}")
  namespace=$(yq -r '.spec.cluster.namespace // "default"' "${cluster_yaml}")

  credentials::require "${provider}" || return 1

  case "${provider}" in
    hetzner)
      kubectl create secret generic "${secret_name}" \
        --namespace "${namespace}" \
        --kubeconfig "${kubeconfig}" \
        --from-literal=hcloud-token="${HCLOUD_TOKEN}" \
        --from-literal=robot-user="${HROBOT_USER:-}" \
        --from-literal=robot-password="${HROBOT_PASSWORD:-}" \
        --dry-run=client -o yaml | kubectl apply --kubeconfig "${kubeconfig}" -f -
      ;;
    aws)
      : "${AWS_REGION:?AWS_REGION required for AWS provider}"
      kubectl create secret generic "${secret_name}" \
        --namespace "${namespace}" \
        --kubeconfig "${kubeconfig}" \
        --from-literal=access-key-id="${AWS_ACCESS_KEY_ID}" \
        --from-literal=secret-access-key="${AWS_SECRET_ACCESS_KEY}" \
        --from-literal=region="${AWS_REGION}" \
        --dry-run=client -o yaml | kubectl apply --kubeconfig "${kubeconfig}" -f -
      ;;
    *)
      error "Unsupported provider for credentials: ${provider}"
      return 1
      ;;
  esac
}

# Wait for a CAPI cluster to become ready.
# Usage: capi::wait_ready <kubeconfig> <cluster_name> [timeout_seconds]
capi::wait_ready() {
  local kubeconfig="$1" cluster_name="$2" timeout="${3:-600}"
  local elapsed=0 interval=10

  debug "Waiting for CAPI cluster ${cluster_name} to become ready (timeout: ${timeout}s)"

  while (( elapsed < timeout )); do
    local phase
    phase=$(kubectl get cluster "${cluster_name}" \
      --kubeconfig "${kubeconfig}" \
      -o jsonpath='{.status.phase}' 2>/dev/null || echo "")

    if [[ "${phase}" == "Provisioned" ]]; then
      debug "Cluster ${cluster_name} is Provisioned"
      return 0
    fi

    debug "Cluster ${cluster_name} phase: ${phase:-Unknown} (${elapsed}/${timeout}s)"
    sleep "${interval}"
    elapsed=$(( elapsed + interval ))
  done

  error "Timed out waiting for cluster ${cluster_name} (${timeout}s)"
  return 1
}
