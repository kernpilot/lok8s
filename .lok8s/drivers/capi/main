#!/usr/bin/env argsh
# shellcheck shell=bash disable=SC2034
# vim: set syntax=bash:
# Capi driver — production clusters via Cluster API
# Implements: driver::provision, driver::destroy, driver::status, driver::kubeconfig
# Capi-specific: capi::bootstrap (management cluster bootstrap)
#
# Full CAPI logic (detect_provider, generate, wait_ready, ensure_credentials)
# lives in the sibling drivers/capi/generate — imported here so the driver is
# self-contained (a driver's main must pull in all of its own siblings; see
# CONTRACT). Do NOT rely on `lo` pre-importing it.

import ^utils/verbose
import ^drivers/capi/generate

# ── CLI dispatch ──────────────────────────────────────────

main::driver() {
  local -a usage=(
    'provision|p@destructive'  'Provision a CAPI cluster'
    'destroy|d@destructive'    'Destroy a CAPI cluster'
    'status|s@readonly'        'Check cluster status'
    'kubeconfig|k@readonly'    'Extract kubeconfig path'
  )
  :usage "CAPI driver" "${@}"
  "${usage[@]}"
}

# ── Driver contract ───────────────────────────────────────

driver::provision() {
  local domain
  local -a args=(
    'domain'  'Domain to use'
  )
  :args "Provision a CAPI cluster" "${@}"

  local cluster_yaml="${PATH_CLUSTERS}/${domain}/cluster.lok8s.yaml"

  # 1. Determine management cluster
  local mgmt_domain mgmt_local namespace
  mgmt_domain=$(yq -r '.spec.managementCluster.domain // ""' "${cluster_yaml}")
  mgmt_local=$(yq -r '.spec.managementCluster.local // false' "${cluster_yaml}")
  namespace=$(yq -r '.spec.cluster.namespace // "default"' "${cluster_yaml}")

  if [[ -z "${mgmt_domain}" ]]; then
    kubehz::read_config "${cluster_yaml}"
    if [[ "${LOK8S_KUBEHZ_HOSTING}" != "hosted" ]]; then
      error "spec.managementCluster.domain is required for self-hosted CAPI"
      error "set spec.kubehz.hosting: hosted to use the kubehz seed cluster"
      return 1
    fi
    kubehz::provision_hosted "${domain}" "${cluster_yaml}"
    return
  fi

  # 2. Detect the infra provider (needed to set up the management cluster).
  local provider
  provider=$(capi::detect_provider "${cluster_yaml}")

  # 3. Ensure a management cluster exists.
  local mgmt_kubeconfig="${PATH_BASE}/.kubeconfig/${mgmt_domain}.yaml"
  if [[ "${domain}" == "${mgmt_domain}" && ! -f "${mgmt_kubeconfig}" ]]; then
    # The domain IS the management cluster — bootstrap it on the provider.
    echo "info: bootstrapping management cluster ${mgmt_domain}" >&2
    capi::bootstrap "${domain}" "${cluster_yaml}"
    return $?
  fi
  if [[ ! -f "${mgmt_kubeconfig}" ]]; then
    if [[ "${mgmt_local}" == "true" ]]; then
      # Cheap, self-contained model: a local kind cluster as the CAPI
      # management cluster (real workload nodes still on the cloud provider).
      capi::ensure_local_mgmt "${mgmt_domain}" "${provider}" || return 1
    else
      error "management cluster kubeconfig not found: ${mgmt_kubeconfig}"
      error "provision it first ('lo provision ${mgmt_domain}'), or set spec.managementCluster.local: true"
      return 1
    fi
  fi

  # 4. Ensure the cluster namespace + credential Secret exist on the mgmt cluster.
  kubectl --kubeconfig "${mgmt_kubeconfig}" create namespace "${namespace}" \
    --dry-run=client -o yaml | kubectl --kubeconfig "${mgmt_kubeconfig}" apply -f - >&2
  capi::ensure_credentials "${cluster_yaml}" "${provider}" "${mgmt_kubeconfig}"

  # 5. Generate + apply the CAPI resources.
  local resources
  resources=$(capi::generate "${cluster_yaml}" "${provider}") || return 1
  kubectl apply --kubeconfig "${mgmt_kubeconfig}" -f <(echo "${resources}")

  # 6. Wait for the workload cluster to provision. Cloud nodes install the
  #    kubeadm stack via cloud-init, so allow generous time (15m).
  local cluster_name
  cluster_name=$(yq -r '.metadata.name' "${cluster_yaml}")
  capi::wait_ready "${mgmt_kubeconfig}" "${cluster_name}" "${namespace}" 900

  # 7. Extract the workload kubeconfig under the cluster's metadata.name — the
  #    path the framework's bootstrap step (CNI + CCM) and the harness expect.
  #    The kubeconfig secret appears once the control plane is initialized, so
  #    retry briefly.
  mkdir -p "${PATH_BASE}/.kubeconfig"
  local kc="${PATH_BASE}/.kubeconfig/${cluster_name}.yaml" i
  for i in $(seq 1 30); do
    if clusterctl get kubeconfig "${cluster_name}" \
        --namespace "${namespace}" \
        --kubeconfig "${mgmt_kubeconfig}" > "${kc}" 2>/dev/null && [[ -s "${kc}" ]]; then
      break
    fi
    sleep 10
  done
  [[ -s "${kc}" ]] || { error "could not extract workload kubeconfig for ${cluster_name}"; return 1; }

  # 8. Wait for the workload API server to answer before the framework applies
  #    the CNI + CCM (the control-plane node still has to finish kubeadm init).
  #    Fail (so the harness tears down) if it never comes up — otherwise the
  #    framework would apply bootstrap addons against a dead cluster.
  echo "info: waiting for the workload API server to become reachable" >&2
  local reachable=0
  for i in $(seq 1 60); do
    if kubectl --kubeconfig "${kc}" get --raw='/readyz' &>/dev/null; then reachable=1; break; fi
    sleep 10
  done
  if (( ! reachable )); then
    error "workload API server for ${cluster_name} did not become reachable"
    return 1
  fi
}

# Post-provision hook (called by provision::dispatch before bootstrap addons).
# The Hetzner CCM reads its token from the `hcloud` secret (key `token`) in
# kube-system on the WORKLOAD cluster; create it here so the `ccm` bootstrap
# addon finds it. The token is passed via a temp file, never a process arg.
driver::post_provision() {
  local domain
  local -a args=(
    'domain'  'Domain to use'
  )
  :args "Capi post-provision" "${@}"

  local cluster_yaml="${PATH_CLUSTERS}/${domain}/cluster.lok8s.yaml"
  local cluster_name provider kubeconfig
  cluster_name=$(yq -r '.metadata.name' "${cluster_yaml}")
  provider=$(capi::detect_provider "${cluster_yaml}")
  kubeconfig="${PATH_BASE}/.kubeconfig/${cluster_name}.yaml"
  [[ -f "${kubeconfig}" ]] || return 0

  if [[ "${provider}" == "hetzner" && -n "${HCLOUD_TOKEN:-}" ]]; then
    local tf
    tf=$(mktemp)
    # Always remove the token temp file, even on apply failure / interrupt.
    trap 'rm -f "${tf}"' RETURN
    printf '%s' "${HCLOUD_TOKEN}" > "${tf}"
    kubectl --kubeconfig "${kubeconfig}" -n kube-system create secret generic hcloud \
      --from-file=token="${tf}" --dry-run=client -o yaml \
      | kubectl --kubeconfig "${kubeconfig}" apply -f - >&2
  fi
}

driver::destroy() {
  local domain
  local -a args=(
    'domain'  'Domain to use'
  )
  :args "Destroy a CAPI cluster" "${@}"

  local cluster_yaml="${PATH_CLUSTERS}/${domain}/cluster.lok8s.yaml"
  local mgmt_domain cluster_name namespace mgmt_local
  mgmt_domain=$(yq -r '.spec.managementCluster.domain // ""' "${cluster_yaml}")
  cluster_name=$(yq -r '.metadata.name' "${cluster_yaml}")
  namespace=$(yq -r '.spec.cluster.namespace // "default"' "${cluster_yaml}")
  mgmt_local=$(yq -r '.spec.managementCluster.local // false' "${cluster_yaml}")

  if [[ -z "${mgmt_domain}" ]]; then
    kubehz::read_config "${cluster_yaml}"
    if [[ "${LOK8S_KUBEHZ_HOSTING}" == "hosted" ]]; then
      kubehz::destroy_hosted "${domain}" "${cluster_yaml}"
      return
    fi
    error "spec.managementCluster.domain is required for self-hosted CAPI destroy"
    return 1
  fi

  local mgmt_kubeconfig="${PATH_BASE}/.kubeconfig/${mgmt_domain}.yaml"

  # If the mgmt kubeconfig was lost but the local kind cluster is still up,
  # recover it — otherwise we would delete the kind cluster below with a live
  # workload (and its billed servers) still behind it.
  if [[ ! -f "${mgmt_kubeconfig}" && "${mgmt_local}" == "true" ]]; then
    local _kn; _kn=$(capi::mgmt_kind_name "${mgmt_domain}")
    if kind get clusters 2>/dev/null | grep -qx "${_kn}"; then
      mkdir -p "${PATH_BASE}/.kubeconfig"
      kind get kubeconfig --name "${_kn}" > "${mgmt_kubeconfig}" 2>/dev/null || true
    fi
  fi

  # Delete the workload Cluster and BLOCK until CAPH has deprovisioned the
  # Hetzner servers + load balancer (finalizers complete). Deleting the
  # management cluster before this finishes would orphan billed infrastructure.
  local del_rc=0
  if [[ -f "${mgmt_kubeconfig}" ]]; then
    echo "info: deleting workload cluster ${cluster_name} — waiting for Hetzner teardown (up to 10m)" >&2
    kubectl delete cluster "${cluster_name}" \
      --namespace "${namespace}" \
      --kubeconfig "${mgmt_kubeconfig}" \
      --ignore-not-found=true \
      --wait=true --timeout=600s >&2 || del_rc=$?
  fi

  # Tear down the local kind management cluster we created — but only once the
  # workload teardown actually completed, so CAPH can finish if it is still
  # deleting servers.
  if [[ "${mgmt_local}" == "true" ]]; then
    local kind_name; kind_name=$(capi::mgmt_kind_name "${mgmt_domain}")
    if (( del_rc == 0 )); then
      echo "info: deleting local kind management cluster '${kind_name}'" >&2
      export KIND_EXPERIMENTAL_DOCKER_NETWORK="${KIND_EXPERIMENTAL_DOCKER_NETWORK:-lok8s-example}"
      kind delete cluster --name "${kind_name}" 2>/dev/null || true
      rm -f "${mgmt_kubeconfig}"
    else
      error "workload cluster delete did not complete — KEEPING the management cluster so CAPH can finish deprovisioning."
      error "check 'hcloud server list' and re-run 'lo down', or inspect: kubectl --kubeconfig ${mgmt_kubeconfig} get cluster,machine -A"
    fi
  fi
  rm -f "${PATH_BASE}/.kubeconfig/${cluster_name}.yaml"
}

driver::status() {
  local domain
  local -a args=(
    'domain'  'Domain to use'
  )
  :args "Check CAPI cluster status" "${@}"

  local cluster_yaml="${PATH_CLUSTERS}/${domain}/cluster.lok8s.yaml"
  local mgmt_domain cluster_name
  mgmt_domain=$(yq -r '.spec.managementCluster.domain // ""' "${cluster_yaml}")
  cluster_name=$(yq -r '.metadata.name' "${cluster_yaml}")

  if [[ -z "${mgmt_domain}" ]]; then
    echo "Unknown"
    return
  fi

  local mgmt_kubeconfig="${PATH_BASE}/.kubeconfig/${mgmt_domain}.yaml"
  kubectl get cluster "${cluster_name}" --kubeconfig "${mgmt_kubeconfig}" \
    -o jsonpath='{.status.phase}' 2>/dev/null || echo "NotFound"
}

driver::kubeconfig() {
  local domain
  local -a args=(
    'domain'  'Domain to use'
  )
  :args "Extract kubeconfig" "${@}"

  # Written under the workload cluster's metadata.name (see driver::provision).
  local cluster_yaml="${PATH_CLUSTERS}/${domain}/cluster.lok8s.yaml"
  local cluster_name
  cluster_name=$(yq -r '.metadata.name' "${cluster_yaml}")
  echo "${PATH_BASE}/.kubeconfig/${cluster_name}.yaml"
}

# Optional contract function — Capi needs credential setup
driver::ensure_credentials() {
  local cluster_yaml="$1" provider="$2" kubeconfig="$3"

  credentials::require "${provider}" || return 1

  # Delegate to capi::ensure_credentials from drivers/capi/generate
  capi::ensure_credentials "${cluster_yaml}" "${provider}" "${kubeconfig}"
}

# Deterministic kind cluster name for a management domain (kind forbids dots).
# ensure_local_mgmt (create) and driver::destroy (delete) must agree, so the
# name is derived in one place. e.g. capi-mgmt.lok8s.dev -> capi-mgmt-lok8s-dev
capi::mgmt_kind_name() { echo "${1//[._]/-}"; }

# Create (or reuse) a LOCAL kind cluster as the CAPI management cluster and
# install Cluster API + the infra provider on it. Used when the cluster spec
# sets managementCluster.local: true — the cheap, self-contained dev model
# (kind management locally, real workload nodes on the cloud provider).
# Usage: capi::ensure_local_mgmt <mgmt_domain> <provider>
capi::ensure_local_mgmt() {
  local mgmt_domain="$1" provider="$2"
  local mgmt_kubeconfig="${PATH_BASE}/.kubeconfig/${mgmt_domain}.yaml"
  local kind_name; kind_name=$(capi::mgmt_kind_name "${mgmt_domain}")

  # Pin the provider versions so the example is reproducible (and matches what
  # the driver was validated against) rather than tracking clusterctl's latest.
  local capi_version="v1.13.2" infra infra_version
  case "${provider}" in
    hetzner) infra="hetzner"; infra_version="v1.1.7" ;;
    *) error "local management cluster: unsupported provider '${provider}'"; return 1 ;;
  esac

  echo "info: creating local kind management cluster '${kind_name}'" >&2
  export KIND_EXPERIMENTAL_DOCKER_NETWORK="${KIND_EXPERIMENTAL_DOCKER_NETWORK:-lok8s-example}"
  if ! kind get clusters 2>/dev/null | grep -qx "${kind_name}"; then
    kind create cluster --name "${kind_name}" >&2
  fi
  mkdir -p "${PATH_BASE}/.kubeconfig"
  kind get kubeconfig --name "${kind_name}" > "${mgmt_kubeconfig}"

  if kubectl --kubeconfig "${mgmt_kubeconfig}" -n capi-system get deployment capi-controller-manager &>/dev/null; then
    echo "info: Cluster API already installed on '${kind_name}'" >&2
  else
    echo "info: installing Cluster API ${capi_version} + ${infra} ${infra_version} (clusterctl init)" >&2
    clusterctl init \
      --kubeconfig "${mgmt_kubeconfig}" \
      --core "cluster-api:${capi_version}" \
      --bootstrap "kubeadm:${capi_version}" \
      --control-plane "kubeadm:${capi_version}" \
      --infrastructure "${infra}:${infra_version}" \
      --wait-providers >&2
  fi
}

# ── Management cluster bootstrap ─────────────────────────

# Bootstrap a management cluster from scratch.
# Flow: temp kind cluster -> clusterctl init -> apply mgmt CR -> wait ->
#       install operator + CAPI on mgmt -> clusterctl move -> deploy targets -> cleanup
# Usage: capi::bootstrap <domain> <cluster_yaml>
capi::bootstrap() {
  local domain="$1"
  local cluster_yaml="${PATH_CLUSTERS}/${domain}/cluster.lok8s.yaml"
  local bootstrap_name="lok8s-bootstrap"
  local bootstrap_kubeconfig="${PATH_BASE}/.kubeconfig/${bootstrap_name}.yaml"
  local mgmt_kubeconfig="${PATH_BASE}/.kubeconfig/${domain}.yaml"

  # Detect provider for infrastructure flag
  local provider
  provider=$(capi::detect_provider "${cluster_yaml}")

  local infra_provider
  case "${provider}" in
    hetzner) infra_provider="hetzner" ;;
    aws)     infra_provider="aws" ;;
    *)
      echo "error: unsupported provider for bootstrap: ${provider}" >&2
      return 1
      ;;
  esac

  # 1. Create temporary kind bootstrap cluster
  echo "info: creating bootstrap cluster" >&2
  export KIND_EXPERIMENTAL_DOCKER_NETWORK="${KIND_EXPERIMENTAL_DOCKER_NETWORK:-lok8s}"
  if ! kind get clusters 2>/dev/null | grep -q "^${bootstrap_name}$"; then
    kind create cluster --name "${bootstrap_name}"
  fi
  mkdir -p "${PATH_BASE}/.kubeconfig"
  kind get kubeconfig --name "${bootstrap_name}" > "${bootstrap_kubeconfig}"

  # 2. Install CAPI core + infrastructure provider on bootstrap
  echo "info: installing CAPI on bootstrap cluster" >&2
  clusterctl init \
    --kubeconfig "${bootstrap_kubeconfig}" \
    --infrastructure "${infra_provider}" \
    --core cluster-api \
    --wait-providers

  # 3. Ensure credentials on bootstrap cluster
  capi::ensure_credentials "${cluster_yaml}" "${provider}" "${bootstrap_kubeconfig}"

  # 4. Generate and apply management cluster CAPI resources
  echo "info: applying management cluster resources" >&2
  local resources
  resources=$(capi::generate "${cluster_yaml}" "${provider}")
  kubectl apply --kubeconfig "${bootstrap_kubeconfig}" -f <(echo "${resources}")

  # 5. Wait for management cluster to become ready
  local cluster_name
  cluster_name=$(yq -r '.metadata.name' "${cluster_yaml}")
  echo "info: waiting for management cluster to become ready" >&2
  capi::wait_ready "${bootstrap_kubeconfig}" "${cluster_name}"

  # 6. Extract management cluster kubeconfig
  clusterctl get kubeconfig "${cluster_name}" \
    --kubeconfig "${bootstrap_kubeconfig}" \
    > "${mgmt_kubeconfig}"

  # 7. Install lok8s operator on management cluster
  echo "info: installing lok8s operator on management cluster" >&2
  if [[ -d "${PATH_BASE}/operator/deploy" ]]; then
    kubectl apply --kubeconfig "${mgmt_kubeconfig}" \
      -f "${PATH_BASE}/operator/deploy/" 2>/dev/null || true
  fi

  # 8. Install CAPI + providers on management cluster
  echo "info: installing CAPI on management cluster" >&2
  clusterctl init \
    --kubeconfig "${mgmt_kubeconfig}" \
    --infrastructure "${infra_provider}" \
    --core cluster-api \
    --wait-providers

  # 9. Move CAPI resources from bootstrap to management cluster
  echo "info: moving CAPI resources to management cluster" >&2
  clusterctl move \
    --kubeconfig "${bootstrap_kubeconfig}" \
    --to-kubeconfig "${mgmt_kubeconfig}"

  # 10. Delete bootstrap cluster
  echo "info: cleaning up bootstrap cluster" >&2
  kind delete cluster --name "${bootstrap_name}" 2>/dev/null || true
  rm -f "${bootstrap_kubeconfig}"

  echo "info: management cluster ${domain} bootstrapped successfully" >&2
}
