#!/usr/bin/env argsh
# shellcheck shell=bash disable=SC2034
# registry — container registry management (CLI wrapper)
# Reads from .registries.json (generated by config-registry.sh)

import ^utils/verbose

# Source Lo driver utils at file scope for config + registry helpers
_LO_UTILS="${PATH_LOK8S}/drivers/lo/utils"
source "${PATH_LOK8S}/utils/ip.sh"
source "${_LO_UTILS}/defaults.sh"
source "${_LO_UTILS}/config-registry.sh"
source "${_LO_UTILS}/config.sh"
source "${_LO_UTILS}/network.sh"
source "${_LO_UTILS}/registries.sh"

# Ensure config is loaded for the active domain. Idempotent.
_registry_init() {
  [[ -n "${LOK8S_REGISTRY_JSON:-}" ]] && [[ -f "${LOK8S_REGISTRY_JSON}" ]] && return 0
  local _domain="${DOMAIN_NAME:-lok8s.dev}"
  local _cluster_yaml="${PATH_CLUSTERS}/${_domain}/cluster.lok8s.yaml"
  if [[ -f "${_cluster_yaml}" ]]; then
    lo::read_network_config "${_cluster_yaml}"
  fi
}

main::registry() {
  local -a usage=(
    'up|u'     'Spin up registries'
    'down|d'   'Spin down registries'
    'status|s' 'Check registry status'
    'clean|c'  'Clean up registries'
  )
  local shared
  local -a args=(
    'shared|S:+' 'Include shared mirrors (for clean/status)'
    "${args[@]}"
  )
  :usage "Manage registry" "${@}"
  "${usage[@]}"
}

registry::up() {
  _registry_init
  local _domain="${DOMAIN_NAME:-lok8s.dev}"
  local _cluster_yaml="${PATH_CLUSTERS}/${_domain}/cluster.lok8s.yaml"

  lo::network
  if registry::is_shared; then
    lo::registry_network
  fi

  lo::registries "${_domain}" "${_cluster_yaml}"
}

registry::down() {
  _registry_init
  _down_entry() {
    local name="$1" ip="$2" url="$3" domain="$4" host="$5" type="$6"
    local container_info
    container_info=$(registry::container "${name}")
    local reg_name="${container_info%%	*}"
    docker rm -f "${reg_name}" 2>/dev/null || true
  }
  registry::each _down_entry
}

registry::clean() {
  _registry_init

  lo::cleanup_registries "${LOK8S_SPEC_CLUSTER_NAME:-local}"

  if (( ${shared:-0} )); then
    _clean_shared() {
      local name="$1" ip="$2" url="$3" domain="$4" host="$5" type="$6"
      [[ "${type}" == "mirror" ]] || return 0
      local reg_name="lok8s-registry-${name}"
      docker rm -f "${reg_name}" 2>/dev/null || true
      docker volume rm -f "${reg_name}" 2>/dev/null || true
    }
    registry::each _clean_shared

    local net
    net=$(registry::network_name)
    local remaining
    remaining="$(docker network inspect -f '{{len .Containers}}' "${net}" 2>/dev/null || echo 0)"
    if [[ "${remaining}" == "0" ]]; then
      docker network rm "${net}" 2>/dev/null || true
      debug "Removed empty registry network ${net}"
    else
      debug "Registry network ${net} still has ${remaining} container(s), kept"
    fi
  fi
}

registry::status() {
  _registry_init
  _status_entry() {
    local name="$1" ip="$2" url="$3" domain="$4" host="$5" type="$6"
    local container_info label
    container_info=$(registry::container "${name}")
    local reg_name="${container_info%%	*}"
    local reg_network="${container_info##*	}"

    if [[ "${type}" == "mirror" ]] && registry::is_shared; then
      label="[shared]"
      (( ${shared:-0} )) || return 0
    else
      label="[project]"
    fi

    # Look up container by network — avoids name collisions across clusters
    local container_on_network
    container_on_network=$(docker ps --filter "network=${reg_network}" --format '{{.Names}}' 2>/dev/null \
      | grep -x "${reg_name}" || true)

    # TLS mode serves HTTPS (mkcert cert trusted via the host CA store).
    local catalog_url
    catalog_url="$(registry::url "${ip}")/v2/_catalog"
    echo "${label} ${name} (${reg_name}) -> ${catalog_url}"
    if [[ -z "${container_on_network}" ]]; then
      echo "  (not running)"
    else
      local catalog
      if catalog=$(curl -sf --connect-timeout 1 --max-time 2 "${catalog_url}" 2>/dev/null); then
        echo "${catalog}" | jq . 2>/dev/null || echo "  ${catalog}"
      else
        echo "  (running but unreachable)"
      fi
    fi
    echo
  }
  registry::each _status_entry
}
