#!/usr/bin/env argsh
# shellcheck shell=bash disable=SC2034
# kubeone — KubeOne cluster provisioning library
# Detects provider from cluster spec, extracts variables for template rendering,
# generates kubeone.yaml configs, and wraps kubeone CLI operations.
#
# Work directory convention: .lok8s/<domain>/.kubeone/
#   kubeone.yaml   — rendered KubeOneCluster manifest
#   output.json    — tfjson (from hetzner::generate_tfjson or equivalent)

import utils/verbose
import utils/template
import utils/oidc

# ── Provider detection ──────────────────────────────────

# Detect the infrastructure provider from cluster spec fields.
# Usage: kubeone::detect_provider <cluster_yaml>
# Delegates to provider::detect from utils/provider.
kubeone::detect_provider() {
  provider::detect "$1"
}

# ── Variable extraction ─────────────────────────────────

# Extract and export variables from cluster.lok8s.yaml for template rendering.
# Usage: kubeone::extract_vars <cluster_yaml>
# Exports: CLUSTER_NAME, K8S_VERSION, POD_SUBNET, SERVICE_SUBNET,
#          CP_REPLICAS, CNI_PLUGIN, CLOUD_PROVIDER, SSH_USER, SSH_PORT,
#          ADDONS_ENABLED, ADDONS_PATH
kubeone::extract_vars() {
  local cluster_yaml="$1"

  export CLUSTER_NAME K8S_VERSION POD_SUBNET SERVICE_SUBNET
  export CP_REPLICAS CNI_PLUGIN CLOUD_PROVIDER
  export SSH_USER SSH_PORT
  export ADDONS_ENABLED ADDONS_PATH
  # spec.cluster.domain — the cluster's own domain, exported for addon envsubst
  # (${LOK8S_SPEC_CLUSTER_DOMAIN}, e.g. the mailpit chart's default route host
  # mailpit.${LOK8S_SPEC_CLUSTER_DOMAIN}). Mirrors the lo driver's
  # lo::export_spec_envs so the var resolves on EITHER driver (parity).
  export LOK8S_SPEC_CLUSTER_DOMAIN
  # spec.dns.domainFilter — comma-separated zone list for the external-dns
  # framework addon's envsubst (${LOK8S_SPEC_DNS_DOMAINFILTER}). Mirrors the lo
  # driver's lo::export_spec_envs: external-dns runs on prod (KubeOne), and this
  # export persists into bootstrap::apply (same process), so the addon render
  # substitutes the zone list instead of leaving it empty.
  export LOK8S_SPEC_DNS_DOMAINFILTER

  # spec.oidc — KubeOne features.openidConnect inputs (consumed by
  # kubeone::_inject_oidc, which yq-merges them into the manifest's features
  # block). Absent spec.oidc ⇒ ISSUER/CLIENTID empty ⇒ oidc::enabled false ⇒ NO
  # apiserver OIDC wiring (the kubeone.yaml is rendered unchanged). Defaults
  # mirror the schema doc in utils/oidc.sh and the lo driver's export.
  export LOK8S_SPEC_OIDC_ISSUER LOK8S_SPEC_OIDC_CLIENTID
  export LOK8S_SPEC_OIDC_USERNAMECLAIM LOK8S_SPEC_OIDC_USERNAMEPREFIX
  export LOK8S_SPEC_OIDC_GROUPSCLAIM LOK8S_SPEC_OIDC_GROUPSPREFIX
  export LOK8S_SPEC_OIDC_CABUNDLE

  CLUSTER_NAME=$(yq -r '.metadata.name' "${cluster_yaml}")
  K8S_VERSION=$(yq -r '.spec.kubernetes.version' "${cluster_yaml}")
  LOK8S_SPEC_CLUSTER_DOMAIN=$(yq -r '.spec.cluster.domain // ""' "${cluster_yaml}")
  LOK8S_SPEC_DNS_DOMAINFILTER=$(yq -r '.spec.dns.domainFilter // ""' "${cluster_yaml}")
  LOK8S_SPEC_OIDC_ISSUER=$(yq -r '.spec.oidc.issuer // ""' "${cluster_yaml}")
  LOK8S_SPEC_OIDC_CLIENTID=$(yq -r '.spec.oidc.clientID // ""' "${cluster_yaml}")
  LOK8S_SPEC_OIDC_USERNAMECLAIM=$(yq -r '.spec.oidc.usernameClaim // "sub"' "${cluster_yaml}")
  LOK8S_SPEC_OIDC_USERNAMEPREFIX=$(yq -r '.spec.oidc.usernamePrefix // "oidc:"' "${cluster_yaml}")
  LOK8S_SPEC_OIDC_GROUPSCLAIM=$(yq -r '.spec.oidc.groupsClaim // "groups"' "${cluster_yaml}")
  LOK8S_SPEC_OIDC_GROUPSPREFIX=$(yq -r '.spec.oidc.groupsPrefix // "oidc:"' "${cluster_yaml}")
  LOK8S_SPEC_OIDC_CABUNDLE=$(yq -r '.spec.oidc.caBundle // ""' "${cluster_yaml}")
  POD_SUBNET=$(yq -r '.spec.network.podSubnet // "10.244.0.0/16"' "${cluster_yaml}")
  SERVICE_SUBNET=$(yq -r '.spec.network.serviceSubnet // "10.96.0.0/12"' "${cluster_yaml}")
  CP_REPLICAS=$(yq -r '.spec.controlPlane.replicas // 1' "${cluster_yaml}")
  CNI_PLUGIN=$(yq -r '.spec.network.cni // "canal"' "${cluster_yaml}")

  # Map provider name to KubeOne cloudProvider key
  local provider
  provider=$(kubeone::detect_provider "${cluster_yaml}")
  CLOUD_PROVIDER="${provider}"

  # SSH config — read from provider output access[] if available,
  # fall back to spec.ssh for backward compatibility
  if [[ -n "${PROVIDER_CONFIG_FILE:-}" ]] && declare -F provider::output &>/dev/null; then
    local _output
    _output=$(provider::output "${PROVIDER_CONFIG_FILE}" 2>/dev/null) || true
    if [[ -n "${_output}" ]]; then
      SSH_USER=$(echo "${_output}" | jq -r '.access[0].user // "root"')
      SSH_PORT=$(echo "${_output}" | jq -r '.access[0].port // 22')
      SSH_PRIVATE_KEY=$(echo "${_output}" | jq -r '.access[0].privateKey // ""')
      SSH_PUBLIC_KEY=$(echo "${_output}" | jq -r '.access[0].publicKey // ""')
    fi
  fi
  : "${SSH_USER:=$(yq -r '.spec.ssh.user // "root"' "${cluster_yaml}")}"
  : "${SSH_PORT:=$(yq -r '.spec.ssh.port // 22' "${cluster_yaml}")}"

  # Addons
  ADDONS_ENABLED=$(yq -r '.spec.addons.enabled // "false"' "${cluster_yaml}")
  ADDONS_PATH=$(yq -r '.spec.addons.path // "./addons"' "${cluster_yaml}")
}

# ── OIDC (KubeOne-native features.openidConnect) ─────────

# Inject features.openidConnect into the kubeone manifest from spec.oidc. KubeOne
# wires these into the kubeadm ClusterConfiguration itself, so they propagate to
# EVERY control plane — init AND join — natively: no scp, no file on the node, no
# CA-dir mount, no join-wipe.
#
# (We previously used StructuredAuthenticationConfiguration via
# --authentication-config, but KubeOne's controlPlaneComponents.apiServer exposes
# only `flags` — no extraVolumes — so the auth-config file had to ride a host CA
# dir that `kubeadm join` EMPTIES on joiners, crashlooping their apiservers.
# features.openidConnect is KubeOne's native, field-for-field equivalent for our
# use: single IdP + sub/groups claims. The only things it lacks vs structured
# auth — multi-provider, CEL claim expressions, dynamic reload — we don't use.)
#
# No-op unless oidc::enabled. Usage: kubeone::_inject_oidc <kubeone.yaml>
kubeone::_inject_oidc() {
  local manifest="$1"
  oidc::enabled || return 0
  [[ -f "${manifest}" ]] || { error "OIDC: manifest not found: ${manifest}"; return 1; }

  OIDC_ISSUER="${LOK8S_SPEC_OIDC_ISSUER}"           OIDC_CLIENTID="${LOK8S_SPEC_OIDC_CLIENTID}" \
  OIDC_UCLAIM="${LOK8S_SPEC_OIDC_USERNAMECLAIM}"     OIDC_UPREFIX="${LOK8S_SPEC_OIDC_USERNAMEPREFIX}" \
  OIDC_GCLAIM="${LOK8S_SPEC_OIDC_GROUPSCLAIM}"       OIDC_GPREFIX="${LOK8S_SPEC_OIDC_GROUPSPREFIX}" \
  yq -i '
    .features.openidConnect.enable = true |
    .features.openidConnect.config.issuerUrl = strenv(OIDC_ISSUER) |
    .features.openidConnect.config.clientId = strenv(OIDC_CLIENTID) |
    .features.openidConnect.config.usernameClaim = strenv(OIDC_UCLAIM) |
    .features.openidConnect.config.usernamePrefix = strenv(OIDC_UPREFIX) |
    .features.openidConnect.config.groupsClaim = strenv(OIDC_GCLAIM) |
    .features.openidConnect.config.groupsPrefix = strenv(OIDC_GPREFIX)
  ' "${manifest}" || { error "OIDC: failed to inject features.openidConnect"; return 1; }

  # caBundle (optional): KubeOne auto-uploads + mounts the caFile for the
  # openidConnect feature, so a custom-CA issuer just needs the local file +
  # caFile path. kubehz uses a public LE issuer, so this is normally skipped.
  if [[ -n "${LOK8S_SPEC_OIDC_CABUNDLE:-}" ]]; then
    local _cadir="${manifest%/*}/.oidc"; mkdir -p "${_cadir}"
    printf '%s\n' "${LOK8S_SPEC_OIDC_CABUNDLE}" > "${_cadir}/oidc-ca.pem"
    OIDC_CAFILE="${_cadir}/oidc-ca.pem" \
      yq -i '.features.openidConnect.config.caFile = strenv(OIDC_CAFILE)' "${manifest}" \
      || { error "OIDC: failed to set caFile"; return 1; }
  fi
  debug "OIDC: features.openidConnect injected (issuer ${LOK8S_SPEC_OIDC_ISSUER})"
}

# spec.registries → containerd registry auth, resolved from a per-domain secretRef.
# Lets a cluster opt into AUTHENTICATED image pulls (e.g. to dodge docker.io
# anonymous rate limits) WITHOUT putting creds in the manifest: the spec carries
# only `auth.secretRef: {name, namespace}`; we resolve it from the per-domain
# secrets store and write containerRuntime.containerd.registries.<host>.auth so
# EVERY node (CPs + workers) authenticates. No-op without spec.registries — a
# cluster that omits it pulls anonymously, unchanged.
# Usage: kubeone::_inject_registry_auth <kubeone.yaml> <cluster_yaml>
kubeone::_inject_registry_auth() {
  local manifest="$1" cluster_yaml="$2" host sname sns
  while IFS=$'\t' read -r host sname sns; do
    [[ -n "${host}" && -n "${sname}" ]] || continue
    [[ "${host}" =~ ^[a-zA-Z0-9._:-]+$ ]] || { warn "registry auth: skipping invalid host '${host}'"; continue; }
    # `lo secrets env` emits `export KEY=<%q-quoted>` per key — eval is safe.
    local username="" password=""
    eval "$(lo secrets --domain "${DOMAIN_NAME:-}" env --name "${sname}" --namespace "${sns:-provisioning}" 2>/dev/null)"
    if [[ -z "${username:-}" || -z "${password:-}" ]]; then
      warn "registry auth: secret ${sns:-provisioning}/${sname} lacks username/password — '${host}' left anonymous"
      unset username password; continue
    fi
    RUSER="${username}" RPASS="${password}" \
    yq -i ".containerRuntime.containerd.registries.\"${host}\".auth.username = strenv(RUSER) | .containerRuntime.containerd.registries.\"${host}\".auth.password = strenv(RPASS)" "${manifest}" \
      || { error "registry auth: failed to inject '${host}'"; unset username password; return 1; }
    unset username password
    debug "registry auth: ${host} ← ${sns:-provisioning}/${sname}"
  done < <(yq -r '.spec.registries // {} | to_entries | .[] | [.key, (.value.auth.secretRef.name // ""), (.value.auth.secretRef.namespace // "provisioning")] | @tsv' "${cluster_yaml}" 2>/dev/null)
}

# ── Config generation ───────────────────────────────────

# Render kubeone.yaml from core template + cluster spec.
# Appends dynamicWorkers block for each worker pool defined in spec.workers.
# Usage: kubeone::generate_config <cluster_yaml> <provider> <output_dir>
# Writes: <output_dir>/kubeone.yaml
kubeone::generate_config() {
  local cluster_yaml="$1" provider="$2" output_dir="$3"
  local tmpl_dir="${PATH_LOK8S}/drivers/kubeone/cluster"
  local core_tmpl="${tmpl_dir}/core/kubeone.yaml"

  if [[ ! -f "${core_tmpl}" ]]; then
    error "KubeOne core template not found: ${core_tmpl}"
    return 1
  fi

  mkdir -p "${output_dir}"

  # Ensure variables are exported
  kubeone::extract_vars "${cluster_yaml}"

  # Render the core template
  local rendered
  rendered=$(envsubst '${CLUSTER_NAME} ${K8S_VERSION} ${CLOUD_PROVIDER} ${POD_SUBNET} ${SERVICE_SUBNET} ${CNI_PLUGIN}' < "${core_tmpl}")

  # Append dynamicWorkers block if worker pools are defined
  local pool_count
  pool_count=$(yq -r '.spec.workers | keys | length // 0' "${cluster_yaml}" 2>/dev/null || echo "0")

  if (( pool_count > 0 )); then
    rendered+=$'\n\ndynamicWorkers:'

    local pool
    for pool in $(yq -r '.spec.workers | keys[]' "${cluster_yaml}"); do
      # Validate pool name to prevent yq injection
      if [[ ! "${pool}" =~ ^[a-zA-Z0-9][a-zA-Z0-9-]*$ ]]; then
        error "Invalid worker pool name: ${pool} (must be alphanumeric with hyphens)"
        return 1
      fi

      local replicas pool_type
      replicas=$(yq -r ".spec.workers.${pool}.replicas // 1" "${cluster_yaml}")
      pool_type=$(yq -r ".spec.workers.${pool}.type" "${cluster_yaml}")

      rendered+=$'\n'"- name: ${pool}"
      rendered+=$'\n'"  replicas: ${replicas}"
      rendered+=$'\n'"  providerSpec:"
      rendered+=$'\n'"    cloudProviderSpec:"

      case "${provider}" in
        hetzner)
          local datacenter image
          datacenter=$(yq -r '.spec.datacenter // "fsn1"' "${cluster_yaml}")
          image=$(yq -r ".spec.workers.${pool}.image // \"ubuntu-22.04\"" "${cluster_yaml}")
          rendered+=$'\n'"      serverType: \"${pool_type}\""
          rendered+=$'\n'"      location: \"${datacenter}\""
          rendered+=$'\n'"      image: \"${image}\""
          rendered+=$'\n'"      networks:"
          rendered+=$'\n'"        - \"${CLUSTER_NAME}\""
          ;;
        aws)
          local region ami instance_type
          region=$(yq -r '.spec.aws.region // "eu-central-1"' "${cluster_yaml}")
          ami=$(yq -r ".spec.workers.${pool}.ami // \"\"" "${cluster_yaml}")
          instance_type="${pool_type}"
          rendered+=$'\n'"      instanceType: \"${instance_type}\""
          rendered+=$'\n'"      region: \"${region}\""
          if [[ -n "${ami}" ]]; then
            rendered+=$'\n'"      ami: \"${ami}\""
          fi
          ;;
        *)
          error "Unsupported provider for dynamic workers: ${provider}"
          return 1
          ;;
      esac
    done
  fi

  echo "${rendered}" > "${output_dir}/kubeone.yaml"

  # spec.oidc → features.openidConnect, merged into the manifest's features block
  # (no-op without spec.oidc). KubeOne-native: propagates to joiners, no file.
  kubeone::_inject_oidc "${output_dir}/kubeone.yaml" || return 1
  # spec.registries → containerd registry auth (optional; resolves a secretRef).
  kubeone::_inject_registry_auth "${output_dir}/kubeone.yaml" "${cluster_yaml}" || return 1
  debug "Generated kubeone.yaml at ${output_dir}/kubeone.yaml"
}

# ── KubeOne CLI operations ──────────────────────────────

# Run kubeone apply (install or reconcile cluster).
# Usage: kubeone::apply <work_dir>
# Expects: kubeone.yaml + output.json in work_dir
kubeone::apply() {
  local work_dir="$1"

  if [[ ! -f "${work_dir}/kubeone.yaml" ]]; then
    error "kubeone.yaml not found in ${work_dir}"
    return 1
  fi

  local -a args=(
    apply
    --manifest kubeone.yaml
    --auto-approve
  )

  if [[ -f "${work_dir}/output.json" ]]; then
    args+=(--tfjson output.json)
  fi

  # A reinstalled static worker leaves a stale not-Ready node object that
  # trips kubeone's "broken host" preflight (apply aborts). Remove it first —
  # safe: static workers only (never CP/etcd), only a not-Ready node whose
  # host is confirmed wiped (no kubelet.conf). No-op on a fresh cluster.
  kubeone::_clean_reinstalled_workers "${work_dir}"

  # Break the cni:external deadlock DECLARATIVELY — no background apply, no
  # apiserver polling. KubeOne (with cni.external) deploys ccm-hetzner then
  # BLOCKS up to 10m waiting for nodes to be initialised by the CCM, which
  # can't schedule without a CNI. But KubeOne applies CUSTOM addons
  # (spec.addons.path) at its "ensure custom addons" step — which runs BEFORE
  # that CCM-init wait AND before the static-worker join (verified in
  # pkg/tasks/tasks.go: addons.EnsureUserAddons → externalccm.Ensure →
  # joinStaticWorkerNodes). So render OUR cilium + robot-ready CCM into
  # <work_dir>/addons/ and let kubeone apply them there: the CNI comes up in
  # that window → the CCM schedules → the wait clears → the worker joins a
  # robot-aware CCM. Name the Robot servers first so the CCM matches the
  # bare-metal worker by hostname.
  kubeone::render_addons "${work_dir}" || return 1
  kubeone::_name_robot_workers "${work_dir}/kubeone.yaml"

  debug "Running (in ${work_dir}): kubeone ${args[*]}"
  # Subshell cd: kubeone writes <cluster>-kubeconfig into the CWD (no output
  # flag) — run inside the work dir so artifacts land there. Hetzner Robot
  # credentials ride along for the CCM.
  (
    cd "${work_dir}" || exit 1
    [[ -z "${HROBOT_USER:-}" ]]     || export ROBOT_USER="${HROBOT_USER}" HETZNER_ROBOT_USER="${HROBOT_USER}"
    [[ -z "${HROBOT_PASSWORD:-}" ]] || export ROBOT_PASSWORD="${HROBOT_PASSWORD}" HETZNER_ROBOT_PASSWORD="${HROBOT_PASSWORD}"
    kubeone "${args[@]}"
  )
}

# Remove stale not-Ready node objects for static workers whose host has been
# reinstalled (no /etc/kubernetes/kubelet.conf), so `kubeone apply` re-joins
# them instead of aborting on its "broken host" preflight. Runs kubectl on
# the leader CP (it has admin.conf). Strictly scoped: static workers only
# (CP/etcd nodes are NEVER touched — that needs deliberate quorum handling),
# only nodes that exist AND are not Ready, only when the host is confirmed
# wiped. No-op on a fresh cluster (no reachable CP → nothing to clean).
# Usage: kubeone::_clean_reinstalled_workers <work_dir>
kubeone::_clean_reinstalled_workers() {
  local work_dir="$1"
  local manifest="${work_dir}/kubeone.yaml"
  [[ -f "${manifest}" ]] || return 0

  local cp_ip ssh_key
  cp_ip=$(yq -r '.controlPlane.hosts[0].publicAddress // ""' "${manifest}" 2>/dev/null)
  ssh_key=$(yq -r '.controlPlane.hosts[0].sshPrivateKeyFile // ""' "${manifest}" 2>/dev/null)
  # shellcheck disable=SC2088 # literal "~/" prefix match — expanded via $HOME on the same line, not meant to tilde-expand
  [[ "${ssh_key}" != "~/"* ]] || ssh_key="${HOME}/${ssh_key:2}"
  [[ -n "${cp_ip}" ]] || return 0

  local -a ssh_opts=(
    -o IdentitiesOnly=yes -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null
    -o BatchMode=yes -o LogLevel=ERROR -o ConnectTimeout=6
  )
  [[ -z "${ssh_key}" ]] || ssh_opts+=(-i "${ssh_key}")

  # Leader CP reachable + already a cluster? Fresh provision → skip.
  ssh "${ssh_opts[@]}" "root@${cp_ip}" 'test -f /etc/kubernetes/admin.conf' 2>/dev/null || return 0
  local kctl='kubectl --kubeconfig /etc/kubernetes/admin.conf'

  local n i wname wip ready
  n=$(yq -r '.staticWorkers.hosts | length' "${manifest}" 2>/dev/null || echo 0)
  for (( i = 0; i < n; i++ )); do
    wname=$(yq -r ".staticWorkers.hosts[${i}].hostname // \"\"" "${manifest}")
    wip=$(yq -r ".staticWorkers.hosts[${i}].publicAddress // \"\"" "${manifest}")
    [[ -n "${wname}" && -n "${wip}" ]] || continue
    # host freshly reinstalled? (no kubelet config present)
    ssh "${ssh_opts[@]}" "root@${wip}" 'test ! -e /etc/kubernetes/kubelet.conf' 2>/dev/null || continue
    # stale node object that is NOT Ready?
    ready=$(ssh "${ssh_opts[@]}" "root@${cp_ip}" \
      "${kctl} get node ${wname} -o jsonpath='{.status.conditions[?(@.type==\"Ready\")].status}'" 2>/dev/null || echo "")
    [[ -n "${ready}" && "${ready}" != "True" ]] || continue
    warn "kubeone: ${wname} reinstalled (no kubelet) but a stale ${ready}-Ready node exists — removing it so apply re-joins cleanly"
    ssh "${ssh_opts[@]}" "root@${cp_ip}" "${kctl} delete node ${wname} --timeout=20s" >/dev/null 2>&1 || true
  done
}

# Stage OUR cilium (CNI) + robot-ready hcloud CCM (+ its secret) into the kubeone
# addons directory (<work_dir>/addons/), for `kubeone apply` to deploy at its
# "ensure custom addons" step — BEFORE the CCM-init wait + worker join. This is
# what lets the synchronous apply break the cni:external deadlock with no
# background apply / apiserver polling. Renders through addons::render — the SAME
# canonical khelm path the bootstrap engine uses (value stack + kustomize build +
# envsubst) — so what kubeone applies == what bootstrap later reconciles.
# Usage: kubeone::render_addons <work_dir>
kubeone::render_addons() {
  local work_dir="$1" manifest="${work_dir}/kubeone.yaml"
  local addons_dir="${work_dir}/addons"
  # KubeOne runs `cni: external` (no embedded CNI) + external CCM, so the two
  # addons need DIFFERENT placement (kubeone pkg/addons/ensure.go):
  #  - cilium → a NON-embedded-named subdir ("cilium"): there's no embedded CNI
  #    to override, so it's applied as a plain user addon (EnsureUserAddons).
  #    NB a subdir named "cni-cilium" (an embedded name) would be SKIPPED unless
  #    cni:cilium — which is why it must be "cilium".
  #  - ccm → the embedded name ("ccm-hetzner"): EnsureAddonByName applies a
  #    same-named subdir INSTEAD of kubeone's embedded ccm → robot-aware CCM, no
  #    immutable-selector collision.
  # Both land before externalccm's CCM-init wait; the empty root is skipped
  # (applier.go: empty dir → no-op). CLEAN FIRST — the work dir persists across
  # runs, so a stale *.yaml from an earlier render would be picked up by kubeone's
  # root-addon pass and break the fresh one.
  rm -rf "${addons_dir}"
  mkdir -p "${addons_dir}/cilium" "${addons_dir}/ccm-hetzner"
  local api_host; api_host=$(yq -r '.apiEndpoint.host // ""' "${manifest}" 2>/dev/null)
  [[ -n "${api_host}" ]] || { error "render_addons: apiEndpoint.host missing from ${manifest}"; return 1; }

  # cilium (CNI). k8sServiceHost/Port are ${LOK8S_USER_API_*} placeholders in the
  # cilium values.kubeone.yaml — addons::render's envsubst fills them from the env
  # we export here. Same driver/provider value stack the bootstrap would apply.
  export LOK8S_USER_API_HOST="${api_host}" LOK8S_USER_API_PORT="6443"
  addons::render "${PATH_LOK8S}/addons/cilium" kubeone hetzner "" \
    > "${addons_dir}/cilium/cilium.yaml" || { error "render cilium addon failed"; return 1; }

  # ccm (robot-aware) — the addon now ALSO emits the `hcloud` secret (env: token
  # required, HROBOT_* optional → omitted without a bare-metal worker), so the
  # creds the provider loaded into the env render straight in. No kubectl. Inline
  # robot values match the `ccm` bootstrap entry (HCLOUD_NETWORK = networkID).
  local inline=""
  if [[ -n "${HROBOT_USER:-}" && -n "${HROBOT_PASSWORD:-}" ]]; then
    local net_id; net_id=$(yq -r '.cloudProvider.hetzner.networkID // ""' "${manifest}" 2>/dev/null)
    inline=$'env:\n  ROBOT_ENABLED: {value: "true"}\n  HCLOUD_NETWORK_ROUTES_ENABLED: {value: "false"}'
    [[ -z "${net_id}" ]] || inline+=$'\n'"  HCLOUD_NETWORK: {value: \"${net_id}\"}"
  fi
  addons::render "${PATH_LOK8S}/addons/ccm" kubeone hetzner "${inline}" \
    > "${addons_dir}/ccm-hetzner/ccm.yaml" || { error "render ccm addon failed"; return 1; }

  # Context validation: a bare-metal (static) worker MUST have Robot creds in the
  # secret, or the CCM deletes its Node as "gone from the cloud". The generator
  # omits the robot keys when HROBOT_* are unset (keeps the addon portable), so
  # catch the real gap HERE — an early, legible error beats a 10-minute CCM-init
  # timeout + worker flap.
  local nworkers; nworkers=$(yq -r '(.staticWorkers.hosts // []) | length' "${manifest}" 2>/dev/null || echo 0)
  if (( nworkers > 0 )); then
    local rkeys; rkeys=$(yq -r 'select(.kind=="Secret" and .metadata.name=="hcloud") | .data | keys | join(",")' "${addons_dir}/ccm-hetzner/ccm.yaml" 2>/dev/null)
    if [[ "${rkeys}" != *robot-user* || "${rkeys}" != *robot-password* ]]; then
      error "render_addons: bare-metal worker present but Robot creds missing from the hcloud secret"
      error "  fix: lo secrets set --name hetzner --namespace provisioning HROBOT_USER <user> (+ HROBOT_PASSWORD <pass>)"
      return 1
    fi
  fi

  debug "render_addons: cni-cilium + ccm-hetzner overrides (incl. hcloud secret) -> ${addons_dir}"
}

# Name each bare-metal Robot server to match its node hostname (the CCM
# matches Robot servers by name). Usage: kubeone::_name_robot_workers <manifest>
kubeone::_name_robot_workers() {
  local manifest="$1"
  [[ -n "${HROBOT_USER:-}" && -n "${HROBOT_PASSWORD:-}" ]] || return 0
  local n hostname pubip num
  n=$(yq -r '.staticWorkers.hosts | length' "${manifest}" 2>/dev/null || echo 0)
  for (( i = 0; i < n; i++ )); do
    hostname=$(yq -r ".staticWorkers.hosts[${i}].hostname // \"\"" "${manifest}")
    pubip=$(yq -r ".staticWorkers.hosts[${i}].publicAddress // \"\"" "${manifest}")
    [[ -n "${hostname}" && -n "${pubip}" ]] || continue
    num=$(curl -sS -u "${HROBOT_USER}:${HROBOT_PASSWORD}" \
      "https://robot-ws.your-server.de/server" 2>/dev/null \
      | jq -r --arg ip "${pubip}" '.[].server | select(.server_ip==$ip) | .server_number' 2>/dev/null | head -1)
    [[ -n "${num}" ]] || continue
    curl -sS -u "${HROBOT_USER}:${HROBOT_PASSWORD}" \
      -d "server_name=${hostname}" "https://robot-ws.your-server.de/server/${num}" >/dev/null 2>&1 || true
    debug "CNI bootstrap: named Robot server ${num} -> ${hostname}"
  done
}

# Run kubeone reset (tear down Kubernetes on existing infrastructure).
# Usage: kubeone::reset <work_dir>
kubeone::reset() {
  local work_dir="$1"

  if [[ ! -f "${work_dir}/kubeone.yaml" ]]; then
    error "kubeone.yaml not found in ${work_dir}"
    return 1
  fi

  local -a args=(
    reset
    --manifest "${work_dir}/kubeone.yaml"
    --auto-approve
  )

  if [[ -f "${work_dir}/output.json" ]]; then
    args+=(--tfjson "${work_dir}/output.json")
  fi

  debug "Running: kubeone ${args[*]}"
  kubeone "${args[@]}"
}

# Parse kubeone status output into a single-word status.
# Usage: kubeone::status <work_dir>
# Outputs: Healthy | Degraded | NotFound | Unknown
kubeone::status() {
  local work_dir="$1"

  if [[ ! -f "${work_dir}/kubeone.yaml" ]]; then
    echo "NotProvisioned"
    return
  fi

  local -a args=(
    status
    --manifest "${work_dir}/kubeone.yaml"
  )

  if [[ -f "${work_dir}/output.json" ]]; then
    args+=(--tfjson "${work_dir}/output.json")
  fi

  local output
  if output=$(kubeone "${args[@]}" 2>&1); then
    # Check for known status patterns in kubeone output
    if echo "${output}" | grep -qi "healthy"; then
      echo "Healthy"
    elif echo "${output}" | grep -qi "degraded\|not healthy"; then
      echo "Degraded"
    else
      echo "Unknown"
    fi
  else
    if echo "${output}" | grep -qi "no such file\|not found\|connection refused"; then
      echo "NotFound"
    else
      echo "Unknown"
    fi
  fi
}

# Get kubeconfig path (written by kubeone apply).
# Usage: kubeone::kubeconfig_path <work_dir> <cluster_name>
# Outputs: path to <cluster_name>-kubeconfig
kubeone::kubeconfig_path() {
  local work_dir="$1" cluster_name="$2"
  echo "${work_dir}/${cluster_name}-kubeconfig"
}

# ── Credential validation ───────────────────────────────

# Validate required env vars and SSH key files exist for the given provider.
# Usage: kubeone::validate_credentials <cluster_yaml> <provider>
# Returns 1 with error message if anything is missing.
kubeone::validate_credentials() {
  local cluster_yaml="$1" provider="$2"
  local errors=0

  # Provider-specific env var checks
  credentials::require "${provider}" || errors=$(( errors + 1 ))

  # SSH key file checks — read from provider config, fall back to spec.ssh
  local ssh_public_key ssh_private_key
  if [[ -n "${SSH_PUBLIC_KEY:-}" ]]; then
    ssh_public_key="${SSH_PUBLIC_KEY}"
  else
    ssh_public_key=$(yq -r '.spec.ssh.publicKeyFile // ""' "${cluster_yaml}")
  fi
  if [[ -n "${SSH_PRIVATE_KEY:-}" ]]; then
    ssh_private_key="${SSH_PRIVATE_KEY}"
  else
    ssh_private_key=$(yq -r '.spec.ssh.privateKeyFile // ""' "${cluster_yaml}")
  fi

  # Expand ~ to ${HOME}
  ssh_public_key="${ssh_public_key/#\~/${HOME}}"
  ssh_private_key="${ssh_private_key/#\~/${HOME}}"

  if [[ -n "${ssh_public_key}" ]] && [[ ! -f "${ssh_public_key}" ]]; then
    error "SSH public key file not found: ${ssh_public_key}"
    errors=$(( errors + 1 ))
  fi

  if [[ -n "${ssh_private_key}" ]] && [[ ! -f "${ssh_private_key}" ]]; then
    error "SSH private key file not found: ${ssh_private_key}"
    errors=$(( errors + 1 ))
  fi

  if (( errors > 0 )); then
    error "${errors} credential validation error(s)"
    return 1
  fi

  debug "Credentials validated for provider=${provider}"
  return 0
}
