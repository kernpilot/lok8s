#!/usr/bin/env argsh
# shellcheck shell=bash disable=SC2034
# vim: set syntax=bash:
# addons — list and inspect framework-shipped bootstrap addons
#
# Lists addons from the shared .lok8s/addons/ tree, showing name, type
# (khelm / raw / base), and version (parsed from chart.yaml for khelm
# addons). Addons are framework-level and work with all drivers; the
# active domain's driver (cluster.lok8s.yaml `kind`) only selects which
# values overlay (values.<driver>.yaml) applies at bootstrap time.

import ^utils/types
import ^utils/verbose
import ^utils/template

main::addons() {
  local domain="${domain:-${DOMAIN_NAME:-}}"
  local -a addons
  local -a args=(
    'domain|:^~domain'  'Domain to use'
    'addons'            'List and inspect specific addons'
    "${args[@]:-}"
  )
  :args "Manage cluster addons" "${@}"

  if is::set addons; then
    for ((i=0; i<${#addons[@]}; i++)); do
      addons::show "${addons[$i]}"
      [[ $i -lt $((${#addons[@]} - 1)) ]] &&
        printf "\n---\n"
    done
    return 0
  fi

  addons::list
}

# Resolve the driver kind for the active domain.
# Usage: addons::_driver [domain]
# Echoes lowercase driver name. Falls back to "lo" if no spec found.
# shellcheck disable=SC2120 # optional [domain] arg; callers invoke it arg-less (active domain)
addons::_driver() {
  local _domain="${1:-${domain:-${DOMAIN_NAME:-lok8s.dev}}}"
  local spec="${PATH_CLUSTERS}/${_domain}/cluster.lok8s.yaml"
  if [[ -f "${spec}" ]]; then
    yq -r '.kind // "Lo"' "${spec}" 2>/dev/null | tr '[:upper:]' '[:lower:]'
  else
    echo "lo"
  fi
}

# Resolve the shared addons directory.
addons::_dir() {
  echo "${PATH_LOK8S}/addons"
}

# Classify an addon directory: khelm | raw | base | empty
addons::_type() {
  local dir="$1"
  if [[ -f "${dir}/chart.yaml" ]]; then
    local kind
    kind=$(yq -r '.kind // ""' "${dir}/chart.yaml" 2>/dev/null)
    if [[ "${kind}" == "ChartRenderer" ]]; then
      echo "khelm"
      return
    fi
  fi
  if [[ -f "${dir}/kustomization.yaml" || -f "${dir}/kustomization.yml" ]]; then
    # Has kustomization but no chart.yaml → raw or composition
    echo "raw"
    return
  fi
  echo "empty"
}

# Get version for a khelm addon. Echoes "-" for non-khelm.
addons::_version() {
  local dir="$1"
  if [[ -f "${dir}/chart.yaml" ]]; then
    yq -r '.version // "-"' "${dir}/chart.yaml" 2>/dev/null
  else
    echo "-"
  fi
}

# Get the chart repository URL for a khelm addon.
addons::_repo() {
  local dir="$1"
  if [[ -f "${dir}/chart.yaml" ]]; then
    yq -r '.repository // "-"' "${dir}/chart.yaml" 2>/dev/null
  else
    echo "-"
  fi
}

# Get the chart name for a khelm addon.
addons::_chart() {
  local dir="$1"
  if [[ -f "${dir}/chart.yaml" ]]; then
    yq -r '.chart // "-"' "${dir}/chart.yaml" 2>/dev/null
  else
    echo "-"
  fi
}

# addons::list — print a table of addons for the active driver.
addons::list() {
  local driver addons_dir
  driver=$(addons::_driver)
  addons_dir=$(addons::_dir)

  if [[ ! -d "${addons_dir}" ]]; then
    warn "No addons directory (${addons_dir})"
    return 0
  fi

  printf '%-20s  %-8s  %-12s  %s\n' "NAME" "TYPE" "VERSION" "CHART/REPO"
  printf '%-20s  %-8s  %-12s  %s\n' "----" "----" "-------" "----------"

  local had_entries=0
  local dir
  for dir in "${addons_dir}"/*/; do
    [[ -d "${dir}" ]] || continue
    local name type version chart repo
    name=$(basename "${dir}")
    type=$(addons::_type "${dir}")
    version=$(addons::_version "${dir}")
    chart=$(addons::_chart "${dir}")
    repo=$(addons::_repo "${dir}")
    local detail="-"
    if [[ "${chart}" != "-" ]]; then
      detail="${chart} (${repo})"
    fi
    printf '%-20s  %-8s  %-12s  %s\n' "${name}" "${type}" "${version}" "${detail}"
    had_entries=1
  done

  if (( ! had_entries )); then
    echo "  (no addons available)"
  fi
}

# addons::show — print detail for one or more addons.
# Usage: addons::show <name> [name...]
addons::show() {
  local name="$1"
  [[ -n "${name}" ]] || { error "addon name required"; return 1; }

  local driver addons_dir
  driver=$(addons::_driver)
  addons_dir=$(addons::_dir)
  local dir="${addons_dir}/${name}"

  if [[ ! -d "${dir}" ]]; then
    error "addon '${name}' not found (${dir})"
    return 1
  fi

  echo "name:    ${name}"
  echo "driver:  ${driver}"
  echo "path:    ${dir}"
  echo "type:    $(addons::_type "${dir}")"
  local version chart repo
  version=$(addons::_version "${dir}")
  chart=$(addons::_chart "${dir}")
  repo=$(addons::_repo "${dir}")
  if [[ "${chart}" != "-" ]]; then
    echo "chart:   ${chart}"
    echo "version: ${version}"
    echo "repo:    ${repo}"
  fi
  echo ""
  echo "files:"
  local f
  for f in "${dir}"/*; do
    [[ -f "${f}" ]] || continue
    echo "  - $(basename "${f}")"
  done
}

# Render a framework addon to stdout via the canonical khelm path — the SINGLE
# render shared by the bootstrap engine and the KubeOne driver's pre-apply addon
# staging. Stacks values base < driver(kind) < provider < inline (later wins),
# rewrites the chart's valueFiles to the merged set, then
# `kustomize build --enable-alpha-plugins` + envsubst (LOK8S_USER_* placeholders
# the caller exported, e.g. cilium's k8sServiceHost).
# Usage: addons::render <addon_dir> <kind> <provider_name> [inline_values]
addons::render() {
  local addon_dir="$1" kind="$2" provider_name="${3:-}" inline_values="${4:-}"
  local build_dir="${addon_dir}"
  if [[ -f "${addon_dir}/chart.yaml" ]]; then
    # Stack values: base < driver < provider < inline (later wins). Facts
    # (provider env) beat preferences (driver flavor) beat chart defaults (base);
    # explicit caller intent (inline) beats all.
    local -a value_files=()
    [[ ! -f "${addon_dir}/values.yaml" ]] || value_files+=("${addon_dir}/values.yaml")
    [[ ! -f "${addon_dir}/values.${kind}.yaml" ]] || value_files+=("${addon_dir}/values.${kind}.yaml")
    [[ -z "${provider_name}" ]] || [[ ! -f "${addon_dir}/values.${provider_name}.yaml" ]] \
      || value_files+=("${addon_dir}/values.${provider_name}.yaml")
    # Copy to a mktemp build dir ONLY when there's overlay stacking to do. A chart
    # that pins its OWN chart.yaml valueFiles — e.g. a target referencing a
    # cross-tree base `../../../../.lok8s/addons/<x>/values.yaml` (monitoring,
    # gatus) — must render IN PLACE: a copy breaks those relative paths (they
    # resolve from /tmp → /.lok8s, missing). Stacking addons carry no cross-tree refs.
    if [[ -n "${inline_values}" ]] || (( ${#value_files[@]} > 0 )); then
      build_dir=$(mktemp -d) || { error "addons::render: failed to create temp dir for ${addon_dir}"; return 1; }
      # `/.` (not `/*`) so dotfiles (.helmignore, kustomize overlays, …) come too —
      # a glob drops them and a chart referencing a dotfile would fail to render.
      cp -r "${addon_dir}/." "${build_dir}/" \
        || { error "addons::render: failed to copy ${addon_dir} to temp dir"; rm -rf "${build_dir}"; return 1; }
      if [[ -n "${inline_values}" ]]; then
        printf '%s\n' "${inline_values}" > "${build_dir}/values.inline.yaml"
        value_files+=("${build_dir}/values.inline.yaml")
      fi
      if ! yq eval-all '. as $item ireduce ({}; . * $item)' "${value_files[@]}" \
             > "${build_dir}/values.merged.yaml"; then
        error "addons::render: failed to merge values for ${addon_dir}"
        rm -rf "${build_dir}"; return 1
      fi
      yq -i '.valueFiles = ["values.merged.yaml"]' "${build_dir}/chart.yaml" \
        || { error "addons::render: failed to set valueFiles in chart.yaml for ${addon_dir}"; rm -rf "${build_dir}"; return 1; }
    fi
  fi

  # KHELM_TRUST_ANY_REPO: chart repos are declared in our own version-controlled
  # chart.yaml (the trust boundary is code review), so trust them — no manual
  # `helm repo add`, versions stay pinned.
  # --enable-exec: secrets.lok8s.dev is an exec plugin (an addon may carry a
  # Secret.*.yaml generator next to its chart, e.g. ccm's hcloud secret).
  local whitelist rc=0 out
  whitelist=$(template::envsubst_whitelist)
  # Container env `value`s MUST be strings (k8s schema). Helm coerces numeric
  # values (e.g. cilium's KUBERNETES_SERVICE_PORT from k8sServicePort) back to
  # ints and charts emit them unquoted → `kubectl apply` rejects them. Coerce
  # every container env value to a string; `valueFrom` entries (no `value`) are
  # left untouched.
  out=$(KHELM_TRUST_ANY_REPO=true kustomize build --enable-alpha-plugins --enable-exec "${build_dir}" \
          | envsubst "${whitelist}" \
          | yq eval '(.. | select(tag == "!!map" and has("env") and (.env | tag == "!!seq")) | .env[] | select(has("value")) | .value) |= tostring') || rc=$?
  [[ "${build_dir}" == "${addon_dir}" ]] || rm -rf "${build_dir}"
  # A successful build that yields nothing means the addon rendered no resources —
  # almost always a misconfig (wrong path, everything filtered out). Fail loud
  # rather than report success for an empty apply.
  if (( rc == 0 )) && [[ -z "${out}" ]]; then
    error "addons::render: empty output for ${addon_dir} (no resources rendered)"
    return 1
  fi
  (( rc == 0 )) && printf '%s\n' "${out}"
  return ${rc}
}
[[ "${0}" != "${BASH_SOURCE[0]}" && "${ARGSH_SOURCE:-}" != "${BASH_SOURCE[0]}" ]] || main::addons "${@}"
