#!/usr/bin/env argsh
# shellcheck shell=bash disable=SC2034
# vim: set syntax=bash:
# kubeconfig — emit a kubeconfig for a domain's cluster.
#
# `lo kubeconfig`              print the active domain's cluster kubeconfig
# `lo kubeconfig <domain>`     print that domain's cluster kubeconfig
# `lo kubeconfig --oidc`       print an OIDC kubeconfig: the user authenticates
#                              via the kubelogin exec plugin (kubectl
#                              oidc-login) against spec.oidc's IdP — a PUBLIC
#                              client with PKCE, NO client secret.
#
# The --oidc form reuses the SAME cluster server + CA as the resolved admin
# kubeconfig, but swaps the user for an exec credential plugin. This is the
# kubeconfig a cluster user (not the operator) runs: `kubectl` shells out to
# `kubectl oidc-login get-token`, which drives the browser auth-code+PKCE flow
# and caches the ID token. The apiserver must be wired for the matching OIDC
# issuer (spec.oidc → StructuredAuthenticationConfiguration; see utils/oidc.sh).

import ^utils/types
import ^utils/verbose
import ^utils/oidc
import ^libs/provision

main::kubeconfig() {
  local domain="${domain:-${DOMAIN_NAME:-}}"
  local oidc=0 cluster_override=""
  local -a args=(
    'domain|:^~domain'   'Domain to use (default: active domain)'
    'oidc|o:+'           'Emit an OIDC (kubelogin exec-plugin) kubeconfig instead of the admin one'
    'cluster-override|'  'Override cluster domain for kubeconfig resolution'
    "${args[@]:-}"
  )
  :args "Emit a kubeconfig for a domain's cluster" "${@}"

  # Resolve the cluster admin kubeconfig path for this domain (follows a deploy
  # domain's clusterRef, same as `lo deploy`). Sets KUBECONFIG.
  _resolve_kubeconfig_for_domain
  # For a cluster domain (no deploy.lok8s.yaml), _resolve_kubeconfig_for_domain
  # is a no-op (it only resolves clusterRef chains); fall back to the per-cluster
  # kubeconfig `lo` writes (<metadata.name>.yaml) under .kubeconfig/.
  local kubeconfig="${KUBECONFIG:-}"
  if [[ -z "${kubeconfig}" || ! -f "${kubeconfig}" ]]; then
    kubeconfig=$(kubeconfig::_admin_path "${domain}") || {
      error "could not resolve a kubeconfig for ${domain} (is the cluster provisioned?)"
      return 1
    }
  fi
  if [[ ! -f "${kubeconfig}" ]]; then
    error "kubeconfig not found: ${kubeconfig} (provision the cluster first)"
    return 1
  fi

  if (( oidc )); then
    kubeconfig::emit_oidc "${domain}" "${kubeconfig}"
  else
    cat "${kubeconfig}"
  fi
}

# kubeconfig::_admin_path — the path `lo` writes a provisioned cluster's
# kubeconfig to (<metadata.name>.yaml under .kubeconfig/). Resolves the cluster
# spec for the domain (or its clusterRef). Echoes the path; returns non-zero if
# no cluster spec is found.
# Usage: kubeconfig::_admin_path <domain>
kubeconfig::_admin_path() {
  local domain="$1"
  local domain_dir="${PATH_CLUSTERS}/${domain}"
  local cluster_yaml="${domain_dir}/cluster.lok8s.yaml"

  # Deploy domain → follow clusterRef to the real cluster.
  if [[ ! -f "${cluster_yaml}" && -f "${domain_dir}/deploy.lok8s.yaml" ]]; then
    local ref=""
    ref=$(provision::resolve_clusterref "${domain}" 2>/dev/null) || ref=""
    [[ -n "${ref}" ]] || return 1
    cluster_yaml="${PATH_CLUSTERS}/${ref}/cluster.lok8s.yaml"
  fi
  [[ -f "${cluster_yaml}" ]] || return 1

  local name=""
  name=$(yq -r '.metadata.name // ""' "${cluster_yaml}" 2>/dev/null) || name=""
  [[ -n "${name}" ]] || return 1
  echo "${PATH_BASE}/.kubeconfig/${name}.yaml"
}

# kubeconfig::emit_oidc — emit an OIDC kubeconfig to stdout, reusing the cluster
# server + CA from <src_kubeconfig> and the issuer/clientID from spec.oidc.
# Usage: kubeconfig::emit_oidc <domain> <src_kubeconfig>
kubeconfig::emit_oidc() {
  local domain="$1" src="$2"

  # spec.oidc must be present to build an exec-plugin user.
  if ! oidc::enabled; then
    error "domain '${domain}' has no usable spec.oidc (issuer + clientID required) — cannot emit an OIDC kubeconfig"
    return 1
  fi
  local issuer="${LOK8S_SPEC_OIDC_ISSUER}"
  local client_id="${LOK8S_SPEC_OIDC_CLIENTID}"

  # Pull the cluster stanza from the source kubeconfig — reuse its server + CA
  # verbatim so the OIDC kubeconfig talks to the exact same apiserver endpoint.
  local cluster_name server ca_data ca_file
  cluster_name=$(yq -r '.clusters[0].name // ""' "${src}" 2>/dev/null) || cluster_name=""
  server=$(yq -r '.clusters[0].cluster.server // ""' "${src}" 2>/dev/null) || server=""
  ca_data=$(yq -r '.clusters[0].cluster."certificate-authority-data" // ""' "${src}" 2>/dev/null) || ca_data=""
  ca_file=$(yq -r '.clusters[0].cluster."certificate-authority" // ""' "${src}" 2>/dev/null) || ca_file=""

  if [[ -z "${cluster_name}" || -z "${server}" ]]; then
    error "could not read cluster server/name from ${src}"
    return 1
  fi

  local context_name="${cluster_name}-oidc"
  local user_name="oidc"

  # Header + cluster stanza. Prefer inline CA data; fall back to a CA file path.
  echo "apiVersion: v1"
  echo "kind: Config"
  echo "clusters:"
  echo "  - name: ${cluster_name}"
  echo "    cluster:"
  echo "      server: ${server}"
  if [[ -n "${ca_data}" ]]; then
    echo "      certificate-authority-data: ${ca_data}"
  elif [[ -n "${ca_file}" ]]; then
    echo "      certificate-authority: ${ca_file}"
  fi
  echo "contexts:"
  echo "  - name: ${context_name}"
  echo "    context:"
  echo "      cluster: ${cluster_name}"
  echo "      user: ${user_name}"
  echo "current-context: ${context_name}"

  # The kubelogin (int128/kubelogin) exec credential plugin: kubectl invokes
  # `kubectl oidc-login get-token` (the plugin installs as kubectl-oidc_login).
  # Public client + PKCE: NO --oidc-client-secret. The extra scopes pull the
  # email/groups/profile claims the apiserver maps (see spec.oidc claims).
  # apiVersion client.authentication.k8s.io/v1 is the GA exec-plugin contract
  # (stable since k8s 1.22; valid on the 1.35 target).
  echo "users:"
  echo "  - name: ${user_name}"
  echo "    user:"
  echo "      exec:"
  echo "        apiVersion: client.authentication.k8s.io/v1"
  echo "        command: kubectl"
  echo "        args:"
  echo "          - oidc-login"
  echo "          - get-token"
  echo "          - --oidc-issuer-url=${issuer}"
  echo "          - --oidc-client-id=${client_id}"
  echo "          - --oidc-extra-scope=email"
  echo "          - --oidc-extra-scope=groups"
  echo "          - --oidc-extra-scope=profile"
  # interactiveMode: kubelogin opens a browser; Always is the right hint for a
  # human-driven login. provideClusterInfo not needed (no cluster-info reliance).
  echo "        interactiveMode: IfAvailable"
}

[[ "${0}" != "${BASH_SOURCE[0]}" && "${ARGSH_SOURCE:-}" != "${BASH_SOURCE[0]}" ]] || main::kubeconfig "${@}"
