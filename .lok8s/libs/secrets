#!/usr/bin/env argsh
# shellcheck shell=bash disable=SC2034
# vim: set syntax=bash:
# secrets — secret cache management with SOPS/age encryption
#
# The lok8s secret plugin generates values into $PATH_SECRETS as
# plaintext cache files (Secret.<name>.<ns>.<key>). This module adds
# SOPS/age encryption so those cache files can be committed safely.
#
# Layout (single-instance project — flat store):
#   .secrets/Secret.myapp.default.PASSWORD       ← plaintext (gitignored)
#   .secrets/Secret.myapp.default.PASSWORD.enc   ← SOPS-encrypted (committed)
#   .secrets/tls/                                ← mkcert certs (gitignored)
#
# Per-INSTANCE isolation (multi-domain repos): a domain keeps its OWN secrets
# under clusters/<domain>/secrets/, and the CLI + `lo build` use only that store
# for that domain. This is the secure default for anything serving multiple
# environments — dev/prod never share a generated value, and SOPS creation_rules
# can encrypt each domain's store to DIFFERENT recipients so a dev/CI key cannot
# decrypt prod. There is deliberately NO shared tier: a value needed in two
# instances is a manual copy (the operator consenting to that exposure), never a
# silent fallback. See docs/guide/secrets.md.
#   clusters/kubehz.dev/secrets/Secret.app.default.PASSWORD{,.enc}
#   clusters/kubehz.cloud/secrets/Secret.app.default.PASSWORD{,.enc}
#
# .gitignore (per store):
#   *
#   !.gitignore
#   !Secret.*.enc
#
# Encryption uses age keys derived from SSH keys via ssh-to-age.
# No new key ceremony — your existing ~/.ssh/id_ed25519 is your
# encryption identity.

: "${LOK8S_SSH_KEY:=${HOME}/.ssh/id_ed25519}"

import ^utils/types
import ^utils/verbose

# ── CLI entry ────────────────────────────────────────────

main::secrets() {
  local domain="${domain:-${DOMAIN_NAME:-}}"
  local -a args=(
    'domain|:^~domain'  'Domain to use'
    "${args[@]:-}"
  )
  local -a usage=(
    'init|i@idempotent'     'Initialize SOPS/age encryption from SSH key'
    'set|s@destructive'     'Write a literal value into the secret cache'
    'encrypt|e@idempotent'  'Encrypt plaintext cache files for commit'
    'decrypt|d@idempotent'  'Decrypt .enc files into plaintext cache'
    'allow|a@destructive'   'Approve bash: generators (re-compute .sha + .bash-allow)'
    'list|l@readonly'       'List secrets'
    'print|p@readonly'      'Print secret(s)'
    'path@readonly'         'Resolve the secrets path for the current context'
  )
  :usage "Manage secrets" "${@}"
  "${usage[@]}"
}

# ── Path helpers ─────────────────────────────────────────

# shellcheck disable=SC2120
# Resolve the secrets store for the current context. A domain with its own
# clusters/<domain>/secrets/ uses THAT store exclusively (per-instance isolation,
# no flat fallback for it); otherwise the flat PATH_SECRETS store (single-instance
# projects). `lo build` mirrors this — see build::_export_secrets_path.
secrets::path() {
  :args "Resolve the secrets path for the current context" "${@}"
  if [[ -n "${domain}" && -d "${PATH_CLUSTERS}/${domain}/secrets" ]]; then
    echo "${PATH_CLUSTERS}/${domain}/secrets"
  else
    echo "${PATH_SECRETS:-${PATH_BASE}/.secrets}"
  fi
}

# ── Init ─────────────────────────────────────────────────

secrets::init() {
  local ssh_key="${LOK8S_SSH_KEY}"
  local -a args=(
    'ssh-key|k'  'Path to SSH public key'
    "${args[@]}"
  )
  :args "Initialize SOPS/age encryption" "${@}"

  command -v ssh-to-age &>/dev/null || {
    error "ssh-to-age not found — install via: b install"
    return 1
  }
  command -v sops &>/dev/null || {
    error "sops not found — install via: b install"
    return 1
  }

  [[ -f "${ssh_key}" ]] || {
    error "SSH public key not found: ${ssh_key}"
    error "Generate one with: ssh-keygen -t ed25519"
    return 1
  }

  local age_pubkey
  age_pubkey=$(ssh-to-age < "${ssh_key}") || {
    error "Failed to derive age public key from ${ssh_key}"
    error "Only ed25519 SSH keys are supported"
    return 1
  }

  local sops_config="${PATH_BASE}/.sops.yaml"

  if [[ -f "${sops_config}" ]]; then
    # Check if this key is already present
    if grep -qF "${age_pubkey}" "${sops_config}"; then
      echo "age key already configured in .sops.yaml"
      return 0
    fi
    warn ".sops.yaml exists but doesn't contain this key"
    warn "Add the key manually or use: lo secrets add-key"
    echo "Your age public key: ${age_pubkey}"
    return 0
  fi

  cat > "${sops_config}" <<YAML
# SOPS encryption config for lok8s secret cache files.
# Recipients are age public keys derived from SSH keys via ssh-to-age.
# Add team members with: lo secrets add-key <ssh-pubkey-path>
creation_rules:
  - path_regex: 'Secret\..*'
    age: '${age_pubkey}'
YAML

  echo "Created ${sops_config}"
  echo "Age public key: ${age_pubkey}"
  echo "Derived from: ${ssh_key}"

  # Ensure secrets directory exists with a .gitignore that blocks
  # everything except SOPS-encrypted .enc files.
  local secrets_dir
  secrets_dir=$(secrets::path)
  mkdir -p "${secrets_dir}"
  secrets::_ensure_gitignore "${secrets_dir}"
}

# ── Set ──────────────────────────────────────────────────

secrets::set() {
  # value is pre-initialized (="") so argsh treats it as an OPTIONAL positional;
  # an uninitialized var would be required and reject a missing value BEFORE the
  # stdin/prompt fallback below could run (the "reads stdin if omitted" path).
  local name namespace="default" key value=""
  local -a args=(
    'name|n'       'Secret name (metadata.name from the Secret spec)'
    'namespace|s'  'Secret namespace'
    'key'          'Cache key name (e.g. JWT_SECRET)'
    'value'        'Value to write (reads stdin if omitted)'
    "${args[@]}"
  )
  :args "Write a literal value into the secret cache" "${@}"

  [[ -n "${name}" ]] || { error "Secret --name is required"; return 1; }
  [[ -n "${key}" ]] || { error "Key argument is required"; return 1; }

  if [[ -z "${value}" ]]; then
    if [[ -t 0 ]]; then
      echo -n "Enter value for ${name}/${key}: " >&2
      read -rs value
      echo >&2
    else
      value=$(cat)
    fi
  fi

  [[ -n "${value}" ]] || { error "Empty value"; return 1; }

  local secrets_dir
  secrets_dir=$(secrets::path)
  mkdir -p "${secrets_dir}"

  local cache_file="${secrets_dir}/Secret.${name}.${namespace}.${key}"
  printf '%s' "${value}" > "${cache_file}"
  chmod 0600 "${cache_file}"
  debug "Wrote ${cache_file}"
  echo "Set ${name}/${namespace}/${key}"
}

# ── Encrypt ──────────────────────────────────────────────

secrets::encrypt() {
  :args "Encrypt plaintext cache files for commit" "${@}"

  local secrets_dir
  secrets_dir=$(secrets::path)

  [[ -d "${secrets_dir}" ]] || { warn "No secrets directory: ${secrets_dir}"; return 0; }

  # Ensure .gitignore blocks plaintext before we create .enc files
  secrets::_ensure_gitignore "${secrets_dir}"

  local sops_config="${PATH_BASE}/.sops.yaml"
  [[ -f "${sops_config}" ]] || {
    error "No .sops.yaml found — run: lo secrets init"
    return 1
  }

  local count=0 skipped=0
  local plaintext
  for plaintext in "${secrets_dir}"/Secret.*; do
    [[ -f "${plaintext}" ]] || continue
    # Skip .enc files
    [[ "${plaintext}" != *.enc ]] || continue

    local enc_file="${plaintext}.enc"

    # Skip if .enc is newer than plaintext (already up to date)
    if [[ -f "${enc_file}" && "${enc_file}" -nt "${plaintext}" ]]; then
      skipped=$((skipped + 1))
      continue
    fi

    debug "Encrypting $(basename "${plaintext}")"
    sops encrypt \
      --input-type binary \
      --output-type binary \
      --output "${enc_file}" \
      "${plaintext}" || {
      error "Failed to encrypt $(basename "${plaintext}")"
      return 1
    }
    count=$((count + 1))
  done

  if (( count > 0 )); then
    echo "Encrypted ${count} secret(s)"
  fi
  if (( skipped > 0 )); then
    debug "Skipped ${skipped} (already up to date)"
  fi
  if (( count == 0 && skipped == 0 )); then
    echo "No plaintext secrets found in ${secrets_dir}"
  fi
}

# ── Allow ────────────────────────────────────────────────

secrets::allow() {
  :args "Approve bash: generators after review" "${@}"

  local secrets_dir
  secrets_dir=$(secrets::path)

  [[ -d "${secrets_dir}" ]] || { warn "No secrets directory: ${secrets_dir}"; return 0; }

  # Collect the per-entry hashes from existing .sha files.
  local -a sha_files=()
  local -a hashes=()
  for sha_file in "${secrets_dir}"/*.sha; do
    [[ -f "${sha_file}" ]] || continue
    sha_files+=("${sha_file}")
    local h
    h=$(cat "${sha_file}" | tr -d '[:space:]')
    hashes+=("${h}")
  done

  if (( ${#hashes[@]} == 0 )); then
    echo "No bash: entries found (no .sha files)"
    return 0
  fi

  # Write the approved SET of per-entry hashes (one per line, sorted + unique).
  # The Go plugin treats .bash-allow as a set and requires every bash entry in a
  # (per-target) build to be a member — so a subset build still matches. (Was a
  # single hash-of-all-hashes, which a per-target build's subset could never
  # match — see kustomize/plugins/secret/generator/bash.go verifyBashAllow.)
  local allow_file="${secrets_dir}/.bash-allow"
  printf '%s\n' "${hashes[@]}" | sort -u > "${allow_file}"
  chmod 0600 "${allow_file}"

  echo "Approved ${#sha_files[@]} bash: entry/entries"
  for sf in "${sha_files[@]}"; do
    echo "  $(basename "${sf}")"
  done
}

# ── Decrypt ──────────────────────────────────────────────

secrets::decrypt() {
  local ssh_key="${LOK8S_SSH_KEY}"
  local -a args=(
    'ssh-key|k'  'Path to SSH private key'
    "${args[@]}"
  )
  :args "Decrypt .enc files into plaintext cache" "${@}"

  local secrets_dir
  secrets_dir=$(secrets::path)

  [[ -d "${secrets_dir}" ]] || { warn "No secrets directory: ${secrets_dir}"; return 0; }

  # Resolve the age private key. Checked in order:
  #   1. SOPS_AGE_KEY env var (CI, explicit)
  #   2. SOPS_AGE_KEY_FILE (~/.config/sops/age/keys.txt, SOPS standard)
  #   3. ssh-to-age from SSH private key (only works without passphrase)
  local age_key="${SOPS_AGE_KEY:-}"
  if [[ -z "${age_key}" ]]; then
    local age_key_file="${SOPS_AGE_KEY_FILE:-${HOME}/.config/sops/age/keys.txt}"
    if [[ -f "${age_key_file}" ]]; then
      age_key=$(grep -v '^#' "${age_key_file}" | grep -m1 'AGE-SECRET-KEY-' || true)
    fi
  fi
  if [[ -z "${age_key}" ]]; then
    command -v ssh-to-age &>/dev/null || {
      error "Cannot find age private key. Options:"
      error "  1. Set SOPS_AGE_KEY env var"
      error "  2. Create ${HOME}/.config/sops/age/keys.txt via:"
      error "     ssh-to-age -private-key < ${ssh_key} > \${HOME}/.config/sops/age/keys.txt"
      error "  3. Install ssh-to-age (b install)"
      return 1
    }
    [[ -f "${ssh_key}" ]] || {
      error "SSH private key not found: ${ssh_key}"
      return 1
    }
    age_key=$(ssh-to-age -private-key < "${ssh_key}" 2>/dev/null) || {
      error "Failed to derive age key from ${ssh_key}"
      error "If your SSH key is passphrase-protected, derive once:"
      error "  mkdir -p ~/.config/sops/age"
      error "  ssh-to-age -private-key -i ${ssh_key} > ~/.config/sops/age/keys.txt"
      error "  chmod 600 ~/.config/sops/age/keys.txt"
      error "(you'll be prompted for the passphrase once)"
      return 1
    }
  fi

  local count=0 skipped=0
  local enc_file
  for enc_file in "${secrets_dir}"/Secret.*.enc; do
    [[ -f "${enc_file}" ]] || continue

    local plaintext="${enc_file%.enc}"

    # Skip if plaintext is newer than .enc (already decrypted)
    if [[ -f "${plaintext}" && "${plaintext}" -nt "${enc_file}" ]]; then
      skipped=$((skipped + 1))
      continue
    fi

    debug "Decrypting $(basename "${enc_file}")"
    SOPS_AGE_KEY="${age_key}" sops decrypt \
      --input-type binary \
      --output-type binary \
      --output "${plaintext}" \
      "${enc_file}" || {
      error "Failed to decrypt $(basename "${enc_file}")"
      return 1
    }
    chmod 0600 "${plaintext}"
    count=$((count + 1))
  done

  if (( count > 0 )); then
    echo "Decrypted ${count} secret(s)"
  fi
  if (( skipped > 0 )); then
    debug "Skipped ${skipped} (already up to date)"
  fi
  if (( count == 0 && skipped == 0 )); then
    echo "No encrypted secrets found in ${secrets_dir}"
  fi
}

# ── Helpers ──────────────────────────────────────────────

# Ensure the secrets dir has a .gitignore that blocks plaintext but
# allows .enc files. Creates the file if missing.
secrets::_ensure_gitignore() {
  local dir="$1"
  local gi="${dir}/.gitignore"
  if [[ -f "${gi}" ]] && grep -qF '!Secret.*.enc' "${gi}"; then
    return 0
  fi
  cat > "${gi}" <<'GI'
# Auto-generated by lok8s — ignore everything except SOPS-encrypted
# secret cache files. Plaintext cache entries must never be committed.
*
!.gitignore
!Secret.*.enc
GI
  debug "Created ${gi}"
}

# Check if a file is SOPS-encrypted (binary format starts with specific bytes).
secrets::is_encrypted() {
  local file="$1"
  [[ -f "${file}" ]] || return 1
  # SOPS binary-encrypted files contain the JSON envelope with "sops" metadata.
  # A simpler heuristic: the .enc file exists and is not empty.
  [[ -f "${file}.enc" ]] && [[ -s "${file}.enc" ]]
}

# Check for unencrypted secrets (used by lint).
# Returns 0 if all secrets are encrypted or no secrets exist.
# Returns 1 if any plaintext secret lacks a corresponding .enc file.
secrets::check_unencrypted() {
  local secrets_dir
  secrets_dir=$(secrets::path)
  [[ -d "${secrets_dir}" ]] || return 0

  local found=0
  for plaintext in "${secrets_dir}"/Secret.*; do
    [[ -f "${plaintext}" ]] || continue
    [[ "${plaintext}" != *.enc ]] || continue
    if [[ ! -f "${plaintext}.enc" ]]; then
      warn "Unencrypted secret: $(basename "${plaintext}") — run: lo secrets encrypt"
      found=1
    elif [[ "${plaintext}" -nt "${plaintext}.enc" ]]; then
      warn "Secret changed since last encrypt: $(basename "${plaintext}") — run: lo secrets encrypt"
      found=1
    fi
  done
  return "${found}"
}

# ── List / Print (preserved from original) ───────────────

secrets::list() {
  :args "List secrets" "${@}"

  local secrets_dir
  secrets_dir=$(secrets::path)
  if [[ ! -d "${secrets_dir}" ]]; then
    warn "Secrets directory not found: ${secrets_dir}"
    return 0
  fi
  for secret in "${secrets_dir}"/Secret.*; do
    [[ -f "${secret}" ]] || continue
    [[ "${secret}" != *.enc ]] || continue
    local name
    name=$(basename "${secret}")
    if [[ -f "${secret}.enc" ]]; then
      echo "${name} (encrypted)"
    else
      echo "${name} (plaintext)"
    fi
  done
  # Also list .enc files without a plaintext counterpart (need decrypt)
  for enc in "${secrets_dir}"/Secret.*.enc; do
    [[ -f "${enc}" ]] || continue
    local plaintext="${enc%.enc}"
    [[ -f "${plaintext}" ]] || echo "$(basename "${enc}") (needs decrypt)"
  done
}

secrets::print() {
  local only_one copy
  local -a find args=(
    'only-one|o:+'  'Only print one secret (error if multiple matches)'
    'copy|c:+'      'Copy secret(s) to clipboard (--only-one is implied)'
    'find'          'match all arguments (regex)'
    "${args[@]}"
  )
  :args "Print secret(s)" "${@}"
  if (( copy )); then only_one=1; fi

  local secrets_dir
  secrets_dir=$(secrets::path)

  local -a matches=()
  local name
  for secret in "${secrets_dir}"/Secret.*; do
    [[ -f "${secret}" ]] || continue
    [[ "${secret}" != *.enc ]] || continue
    name="$(basename "${secret}")"
    local m=1
    for f in "${find[@]}"; do
      echo "${name}" | grep -iqE ".*${f}.*" || { m=0; break; }
    done
    (( m )) && matches+=("${secret}")
  done

  if (( only_one )) && [[ ${#matches[@]} != 1 ]]; then
    error "Multiple matches found:"
    for match in "${matches[@]}"; do
      echo -e "${GREEN}${match}${NC}"
    done
    return 1
  fi

  (( ${#matches[@]} )) || { error "No matches found"; return 1; }

  if (( copy )); then
    for cp in "pbcopy" "xclip -selection clipboard" "xsel --clipboard --input" "clip.exe"; do
      command -v "$(echo "${cp}" | cut -d' ' -f1)" &>/dev/null && {
        ${cp} < "${matches[0]}"
        return
      }
    done
    error "No clipboard tool found"
    return 1
  fi

  if [[ ${#matches[@]} == 1 ]]; then
    cat "${matches[0]}"
    return
  fi

  for match in "${matches[@]}"; do
    echo -e "${GREEN}$(basename "${match}")${NC}"
    cat "${match}"
    echo
    echo
  done
}

[[ "${0}" != "${BASH_SOURCE[0]}" && "${ARGSH_SOURCE:-}" != "${BASH_SOURCE[0]}" ]] || main::secrets "${@}"
