#!/usr/bin/env argsh
# shellcheck shell=bash disable=SC2034
# bootstrap — framework-level cluster infrastructure addon system
#
# Applies spec.bootstrap entries after the cluster is provisioned. Works with ALL
# drivers (Lo, KubeOne, Capi, Kkp) — not driver-specific.
#
# Entries form a DAG and apply CONCURRENTLY (capped). Two things create an
# ordering edge: `dependsOn: [name, …]` (wait for those entries' readiness) and
# `wait: true` (a GLOBAL gate — depends on everything before it, and everything
# after depends on it). An entry waits for its own workloads to be Ready only
# when something depends on it (a dep-target) or it is a gate; a pure leaf just
# applies. With no edges every entry runs in parallel. The old strictly-serial
# apply-then-health-wait per entry was the whole ~37min bootstrap phase. See the
# scheduler block below.
#
# Addon resolution:
#   "cilium"          → .lok8s/addons/cilium/
#   "./targets/foo"   → clusters/<domain>/targets/foo/
#   "/absolute/path"  → /absolute/path/
#
# Provider-aware values:
#   addons/cilium/values.yaml          — base (always loaded)
#   addons/cilium/values.lo.yaml       — driver-specific (if exists)
#   addons/cilium/values.hetzner.yaml  — provider-specific (if exists)
#
# Per-entry overrides (map form):
#   bootstrap:
#     - cilium:                       # legacy shim: whole map = helm values
#         encryption: { enabled: true }
#     - ccm:                          # new schema (reserved: values/env/wait/dependsOn)
#         values:                     # helm values (chart addons only)
#           env: { ROBOT_ENABLED: { value: "true" } }
#         env:                        # envsubst overrides (exported around render)
#           LOK8S_USER_FOO: bar
#         wait: true                  # global gate (default false)
#         dependsOn: [cert-manager]   # wait for these entries' readiness first
#
# The inline values are merged as additional Helm values on top of the
# provider-aware defaults.

import ^utils/types
import ^utils/verbose
import ^utils/kapply
import ^libs/addons

# ── CLI entry point ──────────────────────────────────────

main::bootstrap() {
  local domain="${domain:-${DOMAIN_NAME:-}}"
  local -a args=(
    'domain|:^~domain'  'Domain to use'
    "${args[@]:-}"
  )
  :args "Apply bootstrap addons" "${@}"

  local cluster_yaml="${PATH_CLUSTERS}/${domain}/cluster.lok8s.yaml"
  [[ -f "${cluster_yaml}" ]] || { error "cluster spec not found: ${cluster_yaml}"; return 1; }

  local cluster_name
  cluster_name=$(yq -r '.metadata.name' "${cluster_yaml}")
  local kubeconfig="${PATH_BASE}/.kubeconfig/${cluster_name}.yaml"

  bootstrap::apply "${domain}" "${cluster_yaml}" "${kubeconfig}"
}

# ── Bootstrap engine ─────────────────────────────────────

# bootstrap::_resolve_entries <cluster_yaml> <kind>
# Resolve which bootstrap addon entries to apply, one per line (none = no
# output). Pure (no cluster access) so it is unit-testable. Three cases:
#   - explicit non-empty spec.bootstrap → exactly those entries, in order
#   - explicit empty `bootstrap: []`    → nothing (authoritative opt-out)
#   - absent spec.bootstrap             → per-driver default
# The default is per-driver, NOT one-size-fits-all: only `lo` (kind) ships
# without a CNI and must have one bootstrapped. KubeOne deploys its own cilium
# during `kubeone apply`; Capi/Kkp clusters bring their CNI from the
# management cluster / addon set. Defaulting those to [cilium] caused a stray
# cilium apply on managed clusters.
bootstrap::_resolve_entries() {
  local cluster_yaml="$1" kind="$2"
  local -a entries
  # Emit each entry as compact JSON, one per line: a scalar ("cilium",
  # "./targets/x") or a map ({"ccm":{<chart values>}}). JSON keeps a map on a
  # single line (so mapfile doesn't shatter it) and omits YAML comments — so the
  # apply loop reads structured entries instead of string-splitting them.
  mapfile -t entries < <(yq -o=json -I=0 '.spec.bootstrap[]?' "${cluster_yaml}")
  if (( ${#entries[@]} > 0 )); then
    printf '%s\n' "${entries[@]}"
    return 0
  fi
  # Empty result — distinguish a *defined* empty list (opt out) from an
  # *absent* key (fall back to the per-driver default).
  if [[ "$(yq -r '.spec | has("bootstrap")' "${cluster_yaml}")" == "true" ]]; then
    return 0
  fi
  [[ "${kind}" == "lo" ]] && echo "cilium"
  return 0
}

# bootstrap::_parse_entry <domain> <entry-json> <name> <dir> <inline> <env> <wait> <deps> [explicit]
# Parse ONE spec.bootstrap entry (the compact JSON from _resolve_entries) into the
# fields the apply path needs — passed back through namerefs (the trailing args
# are caller variable NAMES). The 9th (explicit) is OPTIONAL: set to "true" iff
# this entry carries an explicit `name:` override, so the caller can treat a name
# collision as a hard error instead of a tolerated basename clash; omit it and a
# throwaway local is used instead (so existing six-out-param callers still work).
# Returns 1 (after printing an error) on a malformed entry or on `values:` set
# against a non-chart target. Pure apart from that one filesystem touch (the
# chart.yaml check).
#
# Entry forms:
#   scalar  "cilium" | "./targets/x" | "/abs/x"   → name/dir only
#   map     {"<name-or-path>": <value>}
#
# The map VALUE is read in one of two schemas:
#   NEW    — it carries a reserved key (values | env | wait | dependsOn | name):
#              values: <helm values>   chart addons ONLY — a kustomize target
#                                       (no chart.yaml) with `values:` is an ERROR
#                                       (`values:` is helm-only).
#              env:    {KEY: val, ...}  envsubst overrides (see _apply_one).
#              wait:   true|false       global barrier gate; default false.
#              dependsOn: [name, ...]   wait for these named entries' READINESS
#                                       before this one (a DAG edge — must be a
#                                       list of entry names; resolved + cycle-
#                                       checked in bootstrap::apply).
#              name:   <identifier>     OVERRIDE this entry's identity (otherwise
#                                       the basename / map-key) — the name used by
#                                       the dependsOn registry, both as a target
#                                       and a reference. Does NOT change addon_dir.
#                                       Disambiguates a basename collision (e.g. a
#                                       `rook-ceph` addon vs a `./targets/rook-ceph`
#                                       target). Non-empty scalar, [A-Za-z0-9._-]+.
#   LEGACY — no reserved key → the WHOLE value map IS the inline helm values
#            (e.g. `- cilium: {encryption: {enabled: true}}`), unchanged from
#            before this flag existed. A legacy chart that needs a *literal*
#            top-level `values`/`env`/`wait`/`dependsOn` helm key must nest it under
#            `values:` (e.g. `ccm: {env: {...}}` → `ccm: {values: {env: {...}}}`).
bootstrap::_parse_entry() {
  local _domain="$1" _entry="$2"
  local -n _o_name="$3" _o_dir="$4" _o_inline="$5" _o_env="$6" _o_wait="$7" _o_deps="$8"
  # 9th out-param (optional): "true" iff this entry sets an explicit `name:`. Fall
  # back to a throwaway local when omitted so six-out-param callers keep working.
  local _bs_discard_explicit=""
  local -n _o_explicit="${9:-_bs_discard_explicit}"
  _o_name=""; _o_dir=""; _o_inline=""; _o_env=""; _o_wait="false"; _o_deps=""; _o_explicit="false"

  local _raw _valjson=""
  if [[ "${_entry}" == \{* ]]; then
    # Map entry {"<name-or-path>": <value>} — must have EXACTLY one key. A
    # multi-key map is a config mistake (and `yq '.[]'` below would emit one
    # value per key, silently mixing them).
    local _nkeys
    _nkeys="$(yq -r 'keys | length' <<<"${_entry}")" \
      || { error "bootstrap: failed to parse addon name from ${_entry}"; return 1; }
    if [[ "${_nkeys}" != "1" ]]; then
      error "bootstrap: entry must be a single-key map, got ${_nkeys} keys: ${_entry}"
      return 1
    fi
    _raw="$(yq -r 'keys | .[0]' <<<"${_entry}")" \
      || { error "bootstrap: failed to parse addon name from ${_entry}"; return 1; }
    _valjson="$(yq -o=json -I=0 '.[]' <<<"${_entry}")" \
      || { error "bootstrap: failed to parse entry value from ${_entry}"; return 1; }
    # The map VALUE must itself be a map (the {values,env,wait} schema, or the
    # legacy whole-map-is-helm-values form) or null/empty. A scalar or sequence
    # value — e.g. `- addon: true` → {"addon":true}, or `- addon: []` →
    # {"addon":[]} — would let the reserved-key / legacy-values logic below run
    # `yq '.values'/'.env'/'.wait'` against a scalar/seq and misbehave. Reject it
    # up front with a clear type.
    local _val_tag
    _val_tag="$(yq -r 'tag' <<<"${_valjson}")" \
      || { error "bootstrap: failed to parse entry value from ${_entry}"; return 1; }
    if [[ "${_val_tag}" != "!!map" && "${_val_tag}" != "!!null" ]]; then
      error "bootstrap: '${_raw}' entry value must be a map of {values,env,wait} or chart values, got ${_val_tag#!!}"
      return 1
    fi
  else
    # Scalar entry — decode the JSON string to its raw value.
    _raw="$(yq -r '.' <<<"${_entry}")" \
      || { error "bootstrap: failed to parse entry ${_entry}"; return 1; }
  fi

  # Resolve <name-or-path> → addon name + dir. Identical rules for a scalar entry
  # and a map key: absolute path, ./|../ path relative to the cluster dir, or a
  # bare framework-addon name.
  if [[ "${_raw}" == /* ]]; then
    _o_dir="${PATH_BASE}${_raw}"; _o_name="$(basename "${_raw}")"
  elif [[ "${_raw}" == ./* || "${_raw}" == ../* ]]; then
    _o_dir="${PATH_CLUSTERS}/${_domain}/${_raw}"; _o_name="$(basename "${_raw}")"
  else
    _o_name="${_raw}"; _o_dir="${PATH_LOK8S}/addons/${_raw}"
  fi

  # Scalar entry (or a map with an empty/null value): nothing more to parse.
  [[ -n "${_valjson}" && "${_valjson}" != "null" ]] || return 0

  if [[ "$(yq -r 'has("values") or has("env") or has("wait") or has("dependsOn") or has("name")' <<<"${_valjson}")" == "true" ]]; then
    # NEW schema.
    # `name:` (optional) OVERRIDES this entry's identifier — the resolved basename
    # (path entries) or map-key (chart entries) — for BOTH the dependsOn registry
    # and as a dependsOn reference target. It does NOT change _o_dir (still the
    # path/map-key). Use it to disambiguate a basename collision (e.g. the
    # `rook-ceph` addon vs a `./targets/rook-ceph` target). Validate as a non-empty
    # scalar in the entry-name charset (same fail-fast spirit as the env-key check).
    if [[ "$(yq -r 'has("name")' <<<"${_valjson}")" == "true" ]]; then
      local _name_tag _oname
      _name_tag="$(yq -r '.name | tag' <<<"${_valjson}")"
      if [[ "${_name_tag}" == "!!map" || "${_name_tag}" == "!!seq" || "${_name_tag}" == "!!null" ]]; then
        error "bootstrap: '${_raw}' name: must be a non-empty scalar entry name (got ${_name_tag#!!})"
        return 1
      fi
      _oname="$(yq -r '.name' <<<"${_valjson}")"
      if [[ -z "${_oname}" ]]; then
        error "bootstrap: '${_raw}' name: must be a non-empty string"
        return 1
      fi
      if [[ ! "${_oname}" =~ ^[A-Za-z0-9._-]+$ ]]; then
        error "bootstrap: '${_raw}' name: '${_oname}' is not a valid entry name (must match [A-Za-z0-9._-]+)"
        return 1
      fi
      _o_name="${_oname}"
      _o_explicit="true"
    fi
    _o_wait="$(yq -r '.wait // false' <<<"${_valjson}")"
    # `wait:` must be a real boolean. A non-boolean scalar (yes/on/1, …) would
    # silently parse as a non-barrier — reject it. A YAML/JSON bool renders as
    # the string "true"/"false" here, the only accepted forms.
    if [[ "${_o_wait}" != "true" && "${_o_wait}" != "false" ]]; then
      error "bootstrap: '${_raw}' has a non-boolean wait: '${_o_wait}' (use true or false)"
      return 1
    fi
    if [[ "$(yq -r 'has("values")' <<<"${_valjson}")" == "true" ]]; then
      # Only flag a non-chart target when the dir EXISTS but lacks chart.yaml.
      # If the dir is missing entirely, stay silent here and let bootstrap::apply
      # surface the authoritative "addon not found" — otherwise a typo'd addon
      # name with `values:` misleads with "not a chart addon" instead.
      if [[ -d "${_o_dir}" && ! -f "${_o_dir}/chart.yaml" ]]; then
        error "bootstrap: '${_raw}' sets 'values:' but is not a chart addon (no chart.yaml under ${_o_dir}); 'values:' is helm-only"
        return 1
      fi
      _o_inline="$(yq -r '.values' <<<"${_valjson}")"
    fi
    if [[ "$(yq -r 'has("env")' <<<"${_valjson}")" == "true" ]]; then
      # The env CONTAINER must itself be a map of KEY: scalar. A sequence or
      # scalar `.env` makes the `to_entries[]` flatten below error out or emit
      # bogus numeric keys (0=…, 1=…) — reject it up front. (A null/empty `env:`
      # is a harmless no-op, matching the `// {}` default used below.)
      local _env_tag
      _env_tag="$(yq -r '.env | tag' <<<"${_valjson}")"
      if [[ "${_env_tag}" != "!!map" && "${_env_tag}" != "!!null" ]]; then
        error "bootstrap: '${_raw}' env: must be a map of KEY: scalar (got ${_env_tag#!!})"
        return 1
      fi
      # env: takes KEY: scalar only. A map/array value would tostring-flatten to
      # a bogus string (e.g. the ccm chart-value `env:` map mistakenly placed at
      # the reserved-key level instead of under values:) — reject it so the
      # mistake is loud, not silent.
      local _bad_env
      _bad_env="$(yq -r '.env // {} | to_entries[] | select((.value | tag == "!!map") or (.value | tag == "!!seq")) | .key' <<<"${_valjson}")"
      if [[ -n "${_bad_env}" ]]; then
        error "bootstrap: '${_raw}' env: values must be scalars; non-scalar value for: ${_bad_env//$'\n'/, } (did you mean values:?)"
        return 1
      fi
      # Each env: key is exported VERBATIM by _apply_one, so it must be a valid
      # POSIX shell variable name. A key containing '-'/'.' , starting with a
      # digit, or empty would make `export` fail or silently misbehave. Validate
      # here (fail fast at parse time, before any apply) with a clear message.
      local _ek
      while IFS= read -r _ek; do
        [[ -n "${_ek}" ]] || continue
        if [[ ! "${_ek}" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
          error "bootstrap: '${_raw}' env: key '${_ek}' is not a valid shell variable name (must match [A-Za-z_][A-Za-z0-9_]*)"
          return 1
        fi
      done < <(yq -r '.env // {} | keys | .[]' <<<"${_valjson}")
      # Flatten env: {KEY: scalar} → newline-separated KEY=val lines (scalar
      # values, coerced to string). Consumed by _apply_one as exported env vars.
      _o_env="$(yq -r '.env // {} | to_entries[] | .key + "=" + (.value | tostring)' <<<"${_valjson}")"
    fi
    if [[ "$(yq -r 'has("dependsOn")' <<<"${_valjson}")" == "true" ]]; then
      # dependsOn: a LIST of entry names this entry must wait for (their READINESS)
      # before it applies — resolved to indices, edge-built, and cycle-checked in
      # bootstrap::apply (which alone knows every entry's name). Validate the SHAPE
      # here (fail fast at parse time, same style as the env CONTAINER check): the
      # container must be a sequence, and every element a scalar name. A map/seq
      # element (e.g. someone nesting a map) is a config mistake — reject it loud.
      local _dep_tag
      _dep_tag="$(yq -r '.dependsOn | tag' <<<"${_valjson}")"
      if [[ "${_dep_tag}" != "!!seq" ]]; then
        error "bootstrap: '${_raw}' dependsOn: must be a list of entry names (got ${_dep_tag#!!})"
        return 1
      fi
      # Each element must be a scalar name; reject map/seq elements. Extract the
      # per-element tag (one per line) and check in bash — yq's `==` precedence
      # inside select() makes a single-expression filter unreliable here.
      local -a _dep_tags=()
      mapfile -t _dep_tags < <(yq -r '.dependsOn[] | tag' <<<"${_valjson}")
      # A null element (`dependsOn: [~]` / a bare `-` list item) is NOT a name: it
      # would coerce to the literal string "null" via tostring below and then fail
      # downstream as a confusing "unknown entry 'null'". Reject it right here at
      # the element-type validation with a clear message.
      if printf '%s\n' "${_dep_tags[@]+"${_dep_tags[@]}"}" | grep -qxF '!!null'; then
        error "bootstrap: '${_raw}' dependsOn: null element — must be a list of entry names"
        return 1
      fi
      if printf '%s\n' "${_dep_tags[@]+"${_dep_tags[@]}"}" | grep -qxE '!!(map|seq)'; then
        error "bootstrap: '${_raw}' dependsOn: each element must be a scalar entry name (got a map/list element)"
        return 1
      fi
      # Flatten to newline-separated names (scalars coerced to string).
      _o_deps="$(yq -r '.dependsOn[] | tostring' <<<"${_valjson}")"
    fi
  else
    # LEGACY shim: the whole value map is the inline helm values.
    _o_inline="$(yq -r '.' <<<"${_valjson}")"
  fi
  return 0
}

# bootstrap::_apply_one <name> <dir> <kind> <provider> <kubeconfig> \
#                       <inline-values> <wait> [env-lines]
# Apply ONE resolved bootstrap entry: the KubeOne cilium/ccm skip, addons::render
# (value-stacking + kustomize build + envsubst), kapply::apply, the
# immutable/terminating fail-fast, the CRD/webhook race-retry, and — only when
# <wait> is non-empty — the post-apply kapply::wait_ready (the readiness wait the
# scheduler requests for dep-targets / gates). Returns 0 on success, 1 on an
# unrecoverable render/apply error.
#
# MUST be invoked in a subshell — `( bootstrap::_apply_one ... )` — so the
# KAPPLY_LAST_OUTPUT global it mutates (and greps right after each apply) stays
# local to this call. The scheduler runs non-barrier entries as concurrent
# background subshells; a shared KAPPLY_LAST_OUTPUT would race across them.
#
# <env-lines> (optional) is a newline-separated list of KEY=VALUE envsubst
# overrides from `- <name>: { env: {...} }`. Each is exported HERE (this subshell
# only — never leaking across entries) before addons::render, so render's envsubst
# whitelist (template::envsubst_whitelist → ${LOK8S_USER_*}/${LOK8S_SPEC_*}) picks
# it up. Name the keys accordingly (e.g. LOK8S_USER_API_HOST) — the same
# convention the addons reference; other names are exported but not whitelisted.
bootstrap::_apply_one() {
  local addon_name="$1" addon_dir="$2" kind="$3" provider_name="$4"
  local kubeconfig="$5" inline_values="$6" do_wait="$7" env_lines="${8:-}"

  if [[ -n "${env_lines}" ]]; then
    local _kv _k _v
    while IFS= read -r _kv; do
      [[ -n "${_kv}" ]] || continue
      _k="${_kv%%=*}"; _v="${_kv#*=}"
      export "${_k}=${_v}"
    done <<< "${env_lines}"
  fi

  # KubeOne applies cilium + the hcloud CCM itself during `kubeone apply` (as
  # rendered custom addons, kubeone::render_addons) to break the cni:external
  # deadlock. When the driver-managed objects are already up, re-applying them
  # here from the kustomize render path is redundant and races the driver for
  # field ownership — so defer both to the driver on KubeOne. Every other driver
  # (Lo/Capi/Kkp) still gets them from bootstrap. Re-run `lo up` to reconcile.
  if [[ "${kind}" == "kubeone" ]]; then
    # Key the skip on the addon DIRECTORY basename, NOT addon_name. A `name:`
    # override changes addon_name (the dependsOn identity) but never addon_dir, so
    # the driver skip must stay anchored to the cilium/ccm addon dir — otherwise a
    # `name:`-renamed cilium/ccm would defeat it and double-apply the driver's own.
    local _ad_base; _ad_base="$(basename "${addon_dir}")"
    if [[ "${_ad_base}" == "cilium" ]] \
       && kubectl --kubeconfig "${kubeconfig}" -n kube-system get ds cilium &>/dev/null; then
      echo "[bootstrap] cilium already deployed by the KubeOne driver — skipping (re-run 'lo up' to reconcile)" >&2
      return 0
    fi
    if [[ "${_ad_base}" == "ccm" ]] \
       && kubectl --kubeconfig "${kubeconfig}" -n kube-system get deploy hcloud-cloud-controller-manager &>/dev/null; then
      echo "[bootstrap] ccm already deployed by the KubeOne driver — skipping (re-run 'lo up' to reconcile)" >&2
      return 0
    fi
  fi

  # Render via the canonical khelm path (value-stacking + kustomize build +
  # envsubst) — the SAME addons::render the KubeOne driver stages addons with.
  debug "bootstrap: rendering ${addon_name}"
  local rendered
  if ! rendered=$(addons::render "${addon_dir}" "${kind}" "${provider_name}" "${inline_values}"); then
    error "bootstrap: render failed for ${addon_name}"
    return 1
  fi

  # Apply with server-side + CRD retry. kapply::apply renders its own
  # (collapsed-on-a-tty) progress, heals immutable / stuck-Terminating conflicts
  # (interactive prompt, or --force-recreate), and passes CRD-not-installed /
  # webhook-not-ready errors through unchanged so the transient-race retry below
  # still fires. A herestring (not a pipe) keeps kapply in this shell so
  # KAPPLY_LAST_OUTPUT is readable here.
  local fp_rc=0
  kapply::apply --label "${addon_name}" --kubeconfig "${kubeconfig}" <<< "${rendered}" || fp_rc=$?

  # Unrecoverable conflict that wasn't healed (declined the prompt, or
  # non-interactive without --force-recreate) — fail fast rather than
  # "succeeding" and letting the next `lo up` / Tilt loop hit the same wall.
  if (( fp_rc != 0 )) && grep -qE 'field is immutable|object is being deleted|because it is being terminated' <<< "${KAPPLY_LAST_OUTPUT}"; then
    error "bootstrap: ${addon_name} has objects blocked by an immutable/terminating conflict — see above (try: lo up --force-recreate)"
    return 1
  fi

  # Transient race between an addon's controllers and the resources they own.
  # Three symptoms: "ensure CRDs are installed first" and "no matches for kind"
  # / "resource mapping not found" (a CR applied before its CRD is Established),
  # and "failed calling webhook" (a CR applied before its validating/mutating
  # webhook is serving — i.e. the webhook Deployment isn't Ready yet).
  local _race='ensure CRDs are installed first|failed calling webhook|no matches for kind|resource mapping not found'

  # Generic apply failure: kapply::apply returned non-zero and the output matches
  # NEITHER an immutable/terminating conflict (handled above) NOR the transient
  # CRD/webhook race (retried below). Fail rather than silently "succeeding" and
  # letting the next `lo up` / Tilt loop hit the same wall.
  if (( fp_rc != 0 )) && ! grep -qE "${_race}" <<< "${KAPPLY_LAST_OUTPUT}"; then
    error "bootstrap: ${addon_name} apply failed (rc=${fp_rc}) — see above"
    return 1
  fi

  if grep -qE "${_race}" <<< "${KAPPLY_LAST_OUTPUT}"; then
    debug "bootstrap: ${addon_name} hit a CRD/webhook race — settling deps before retry"
    # (1) CRDs must be Established before their CRs resolve.
    kapply::run "CRDs established" kubectl --kubeconfig "${kubeconfig}" wait \
      --for=condition=Established crd --all --timeout=60s || true
    # (2) The KEY wait the old single-retry skipped: this addon's own
    #     webhook/controller Deployments must be Available before the resources
    #     they validate will apply. Wait on THIS addon's rendered workloads.
    kapply::wait_ready "${addon_name}" 120 --kubeconfig "${kubeconfig}" <<< "${rendered}" || true
    # (3) Retry with backoff to absorb the brief gap between a webhook
    #     Deployment going Available and its Service endpoints being Ready.
    local _attempt _rc=1 _max=6 _delay=3
    for (( _attempt = 1; _attempt <= _max; _attempt++ )); do
      _rc=0
      kapply::apply --label "${addon_name} (retry ${_attempt}/${_max})" \
        --kubeconfig "${kubeconfig}" <<< "${rendered}" || _rc=$?
      if (( _rc == 0 )) && ! grep -qE "${_race}" <<< "${KAPPLY_LAST_OUTPUT}"; then
        break
      fi
      sleep "${_delay}"
      (( _delay < 15 )) && _delay=$(( _delay + 3 ))
    done
    if (( _rc != 0 )) || grep -qE "${_race}" <<< "${KAPPLY_LAST_OUTPUT}"; then
      error "bootstrap: ${addon_name} still failing after ${_max} retries — CRDs/webhook not ready (see above)"
      return 1
    fi
  fi

  # Post-apply health wait — run it only when the scheduler asks (do_wait set),
  # i.e. when something depends on THIS entry being Ready: a dep-target (someone's
  # dependsOn / a later entry behind a gate) or the entry is itself a wait-gate. A
  # pure leaf skips it (that serial wait was the whole point of the refactor): the
  # scheduler gates readiness only where a dependency edge needs it. _apply_one
  # just honors the flag. Best-effort: a timeout is a ⚠, not fatal — the caller
  # decides whether to care.
  if [[ -n "${do_wait}" ]]; then
    debug "bootstrap: waiting for ${addon_name} workloads to become ready"
    kapply::wait_ready "${addon_name}" 180 --kubeconfig "${kubeconfig}" <<< "${rendered}"
  fi
  return 0
}

# ── Topological-parallel scheduler ───────────────────────
# spec.bootstrap entries form a DAG. An entry runs as soon as its EFFECTIVE
# dependencies have completed, up to LOK8S_BOOTSTRAP_PARALLEL at once — so
# independent CRD-operators (cert-manager, envoy-gateway, cnpg-operator,
# redis-operator, rook-ceph, system-upgrade-controller …) fan out in parallel
# instead of serializing. Two things create an edge:
#   • `dependsOn: [name, …]` — an explicit edge: wait for those entries' READINESS.
#   • `wait: true`           — a GLOBAL gate: it depends on ALL entries before it,
#                              and every entry after it depends on it (the old
#                              "drain all before / ready before anything later"
#                              barrier, expressed as edges).
# An entry waits for its own workloads to be Ready (kapply::wait_ready) IFF
# something depends on it (a dep-target) OR it is a wait-gate; a pure leaf
# (nothing depends on it) just applies and is done. Edge resolution + cycle
# detection live in bootstrap::apply; this collapses the old strictly-serial
# apply-then-wait phase down to roughly the slowest dependency chain.
#
# State is module-level (bash has no closures) so the reap/drain helpers can share
# it with the bootstrap::apply runner; it is reset at the top of every run.
_BS_INFLIGHT=()     # pids of running ( _apply_one ) background jobs
_BS_RCFILES=()      # parallel to _BS_INFLIGHT: each job's rc-capture file
_BS_RUNIDX=()       # parallel to _BS_INFLIGHT: each job's entry INDEX
declare -gA _BS_COMPLETED=()  # set of completed entry indices (index → 1)
_BS_DONE=0          # count of completed entries
_BS_OVERALL_RC=0    # set to 1 if ANY entry failed

# OR a finished job's captured rc into _BS_OVERALL_RC (a missing file = failed).
bootstrap::_collect_rc() {
  local _rcf="$1" _r=1
  [[ -f "${_rcf}" ]] && _r="$(cat "${_rcf}" 2>/dev/null || echo 1)"
  [[ "${_r}" == "0" ]] || _BS_OVERALL_RC=1
}

# Reap every in-flight job (collect rcs + mark each completed), leaving no
# orphan. Used as the final safety flush after the runner loop.
bootstrap::_drain() {
  while (( ${#_BS_INFLIGHT[@]} )); do
    bootstrap::_reap_one
  done
}

# Feature probe: does this bash support `wait -n -p` (5.1+)? Factored into its own
# function so it can be stubbed in tests to force the FIFO fallback path on a
# newer bash (where the live probe would otherwise always take the `wait -n -p`
# branch).
bootstrap::_have_wait_n_p() {
  (( BASH_VERSINFO[0] > 5 || (BASH_VERSINFO[0] == 5 && BASH_VERSINFO[1] >= 1) ))
}

# Free at least one slot: wait for ANY one of OUR in-flight jobs to finish (not
# necessarily the oldest), so one slow job can't block scheduling while faster
# ones have already completed. RESTRICTED to our own pids — never a bare `wait`
# or bare `wait -n` (which could reap a background job owned by the caller, e.g.
# lo provision running bootstrap::apply in-process). On bash 5.1+ this uses
# `wait -n -p <var> <pids…>` (wait for any of the listed pids, capturing which
# one finished); older bash falls back to FIFO `wait <oldest-pid>`. Either way we
# then prune every job that has since finished: collect its rc AND mark its entry
# INDEX completed (so the runner can launch whatever depended on it). rc
# accounting + completion are identical on both reap paths.
bootstrap::_reap_one() {
  (( ${#_BS_INFLIGHT[@]} )) || return 0
  local _finished=""
  if bootstrap::_have_wait_n_p; then
    # bash 5.1+: -n restricted to our pids, -p captures the one that finished.
    wait -n -p _finished "${_BS_INFLIGHT[@]}" 2>/dev/null || true
  fi
  if [[ -z "${_finished}" ]]; then
    # Fallback (bash < 5.1, or -p left it empty): wait the OLDEST pid.
    _finished="${_BS_INFLIGHT[0]}"
    wait "${_finished}" 2>/dev/null || true
  fi
  # Prune the reaped job plus any others that have since died; keep the alive.
  local -a _alive=() _alive_rcf=() _alive_idx=()
  local _i
  for _i in "${!_BS_INFLIGHT[@]}"; do
    if [[ "${_BS_INFLIGHT[_i]}" != "${_finished}" ]] && kill -0 "${_BS_INFLIGHT[_i]}" 2>/dev/null; then
      _alive+=("${_BS_INFLIGHT[_i]}"); _alive_rcf+=("${_BS_RCFILES[_i]}"); _alive_idx+=("${_BS_RUNIDX[_i]}")
    else
      # Explicitly wait the reaped/dead pid so it's removed from the job table
      # (a `kill -0`-dead but un-waited job lingers as a "Done" entry → would look
      # like an orphan). Idempotent for ${_finished} (already reaped → no-op).
      wait "${_BS_INFLIGHT[_i]}" 2>/dev/null || true
      bootstrap::_collect_rc "${_BS_RCFILES[_i]}"
      _BS_COMPLETED["${_BS_RUNIDX[_i]}"]=1
      _BS_DONE=$(( _BS_DONE + 1 ))
    fi
  done
  _BS_INFLIGHT=("${_alive[@]+"${_alive[@]}"}")
  _BS_RCFILES=("${_alive_rcf[@]+"${_alive_rcf[@]}"}")
  _BS_RUNIDX=("${_alive_idx[@]+"${_alive_idx[@]}"}")
}

# bootstrap::apply <domain> <cluster_yaml> <kubeconfig>
# Reads spec.bootstrap from the cluster YAML and runs the entries as a
# topological-parallel DAG (independent entries in parallel, capped at
# LOK8S_BOOTSTRAP_PARALLEL, default 8). Two things add ordering edges: `wait: true`
# is a GLOBAL gate (edges to/from every entry positionally before/after it) and
# `dependsOn:` adds explicit edges. Edge resolution + cycle detection are below
# (see the scheduler block above).
bootstrap::apply() {
  local domain="$1" cluster_yaml="$2" kubeconfig="$3"

  # lo provision drives the bootstrap directly (not via `lo build`), so the
  # per-domain secrets store isn't exported yet. The secrets.lok8s.dev generators
  # (passwd/env/…) read $PATH_SECRETS — without it a target carrying a passwd
  # Secret (e.g. networking's hetzner-dns token) fails to render. Mirror
  # libs/build::_export_secrets_path: point at clusters/<domain>/secrets if present.
  if [[ -d "${PATH_CLUSTERS}/${domain}/secrets" ]]; then
    export PATH_SECRETS="${PATH_CLUSTERS}/${domain}/secrets"
  fi

  [[ -f "${kubeconfig}" ]] || {
    error "bootstrap: kubeconfig not found: ${kubeconfig}"
    return 1
  }

  # Detect driver kind and provider for default policy + values resolution
  local kind provider_name
  kind=$(yq -r '.kind' "${cluster_yaml}" | tr '[:upper:]' '[:lower:]')
  provider_name=$(yq -r '.spec.provider.name // ""' "${cluster_yaml}")

  local -a bootstrap_entries
  mapfile -t bootstrap_entries < <(bootstrap::_resolve_entries "${cluster_yaml}" "${kind}")

  if (( ${#bootstrap_entries[@]} == 0 )); then
    debug "bootstrap: nothing to apply for ${domain} (kind=${kind})"
    return 0
  fi

  # Export the API server endpoint (host + port) parsed from the
  # kubeconfig so addons can target the real control-plane LB endpoint via
  # envsubst — e.g. cilium k8sServiceHost on KubeOne, where the in-cluster
  # ClusterIP (10.96.0.1) is unreachable from a bare-metal worker across
  # the Hetzner vSwitch and the cilium agent hangs on startup. Picked up
  # by template::envsubst_whitelist (LOK8S_USER_* vars).
  local _api_url _api_hostport
  _api_url=$(yq -r '.clusters[0].cluster.server // ""' "${kubeconfig}" 2>/dev/null)
  _api_hostport="${_api_url#https://}"
  _api_hostport="${_api_hostport#http://}"
  if [[ -n "${_api_hostport}" ]]; then
    export LOK8S_USER_API_HOST="${_api_hostport%%:*}"
    local _p="${_api_hostport##*:}"
    [[ "${_p}" != "${_api_hostport}" && -n "${_p}" ]] || _p="6443"
    export LOK8S_USER_API_PORT="${_p}"
    debug "bootstrap: API endpoint ${LOK8S_USER_API_HOST}:${LOK8S_USER_API_PORT} (for addon envsubst)"
  fi

  # ── Plan the DAG: parse every entry, resolve edges, detect cycles ──
  local max_parallel="${LOK8S_BOOTSTRAP_PARALLEL:-8}"
  [[ "${max_parallel}" =~ ^[0-9]+$ ]] && (( max_parallel >= 1 )) || max_parallel=8

  # Parse ALL entries up front into parallel arrays (array index = DAG node).
  local -a _names=() _dirs=() _inlines=() _envs=() _waits=() _depnames=() _explicit=()
  local n=0 entry
  for entry in "${bootstrap_entries[@]}"; do
    [[ -n "${entry}" ]] || continue
    local _nm _dr _in _ev _wt _dp _ex
    bootstrap::_parse_entry "${domain}" "${entry}" _nm _dr _in _ev _wt _dp _ex || return 1
    if [[ ! -d "${_dr}" ]]; then
      error "bootstrap: addon not found: ${entry} (resolved to ${_dr})"
      return 1
    fi
    _names+=("${_nm}"); _dirs+=("${_dr}"); _inlines+=("${_in}")
    _envs+=("${_ev}"); _waits+=("${_wt}"); _depnames+=("${_dp}"); _explicit+=("${_ex}")
    n=$(( n + 1 ))
  done
  (( n > 0 )) || { debug "bootstrap: nothing to apply for ${domain} (kind=${kind})"; return 0; }

  # name → indices sharing it (a multimap). A name on >1 entry is a COLLISION;
  # the handling depends on WHY it collides and whether anything references it:
  #   • an explicit name: on a colliding entry              → hard error here
  #     (a deliberately-set identifier must be unique).
  #   • a basename/map-key collision referenced by dependsOn → hard error below
  #     (ambiguous — the runner can't pick which entry the reference means).
  #   • a basename/map-key collision NOTHING dependsOn       → warn (last-wins),
  #     so a barrier-only config with colliding basenames (e.g. the `rook-ceph`
  #     addon plus a `./targets/rook-ceph` target, no dependsOn) still applies.
  local -A _name2idxs=()
  local _k
  for (( _k = 0; _k < n; _k++ )); do
    _name2idxs["${_names[_k]}"]+=" ${_k}"
  done
  # An explicit name: that collides with ANY other entry (explicit or resolved) is
  # always a hard error — two entries can't share a deliberately-set identity.
  for (( _k = 0; _k < n; _k++ )); do
    [[ "${_explicit[_k]}" == "true" ]] || continue
    local -a _share=()
    read -ra _share <<< "${_name2idxs["${_names[_k]}"]}"
    if (( ${#_share[@]} > 1 )); then
      error "bootstrap: duplicate entry name '${_names[_k]}' — name: must be unique (${#_share[@]} entries share it)"
      return 1
    fi
  done

  # Effective dependency edges, stored as a set of "child,parent" keys (child
  # depends on parent → parent must complete first). Three unioned sources:
  #   1. explicit dependsOn(i)
  #   2. every wait-gate g positionally before i  (a gate ⇒ later entries wait on it)
  #   3. if i is itself a wait-gate: ALL entries before i (a gate ⇒ drain-all-before)
  local -A _edge=()
  for (( _k = 0; _k < n; _k++ )); do
    local _dname _j
    local -a _cand
    while IFS= read -r _dname; do
      [[ -n "${_dname}" ]] || continue
      _cand=()
      [[ -z "${_name2idxs["${_dname}"]:-}" ]] || read -ra _cand <<< "${_name2idxs["${_dname}"]}"
      if (( ${#_cand[@]} == 0 )); then
        error "bootstrap: '${_names[_k]}': dependsOn: unknown entry '${_dname}'"
        return 1
      fi
      # A reference that resolves to a COLLIDED name is ambiguous — error (the
      # warn-only path is reserved for collisions nobody dependsOn). Set an
      # explicit name: on one of the colliding entries to disambiguate.
      if (( ${#_cand[@]} > 1 )); then
        error "bootstrap: '${_names[_k]}': dependsOn: ambiguous entry '${_dname}' (${#_cand[@]} entries share it — set an explicit name:)"
        return 1
      fi
      _j="${_cand[0]}"
      _edge["${_k},${_j}"]=1
    done <<< "${_depnames[_k]}"
    local _g
    for (( _g = 0; _g < _k; _g++ )); do
      [[ "${_waits[_g]}" == "true" ]] && _edge["${_k},${_g}"]=1
      [[ "${_waits[_k]}" == "true" ]] && _edge["${_k},${_g}"]=1
    done
  done

  # Collisions still standing here are basename/map-key clashes that NOTHING
  # dependsOn (a referenced one hard-errored as "ambiguous" above) and carry no
  # explicit name: (those hard-errored too). Warn (last-wins) — visible, but it
  # must NOT break a barrier-only config that happens to reuse a basename.
  local _cn
  for _cn in "${!_name2idxs[@]}"; do
    local -a _cids=()
    read -ra _cids <<< "${_name2idxs["${_cn}"]}"
    (( ${#_cids[@]} > 1 )) \
      && warn "bootstrap: duplicate entry name '${_cn}' — ${#_cids[@]} entries share it; a dependsOn on it would be ambiguous (set an explicit name:)"
  done

  # Derive, from the edge set: per-entry effective deps (space-separated parent
  # indices), the dep-target flag (does anything depend on this entry?), in-degree
  # and reverse adjacency (parent → dependents) — used by cycle-check + runner.
  local -a _edeps=() _istarget=() _indeg=()
  local -A _dependents=()
  for (( _k = 0; _k < n; _k++ )); do _edeps[_k]=""; _istarget[_k]=0; _indeg[_k]=0; done
  local _key _ci _pi
  for _key in "${!_edge[@]}"; do
    _ci="${_key%,*}"; _pi="${_key#*,}"
    _edeps[_ci]+=" ${_pi}"
    _istarget[_pi]=1
    _indeg[_ci]=$(( _indeg[_ci] + 1 ))
    _dependents["${_pi}"]+=" ${_ci}"
  done

  # Cycle detection (Kahn): peel off in-degree-0 nodes; anything left sits in (or
  # behind) a cycle — which would deadlock the runner (nothing in it ever becomes
  # launchable). Fail fast with the offending names.
  local -a _queue=()
  for (( _k = 0; _k < n; _k++ )); do (( _indeg[_k] == 0 )) && _queue+=("${_k}"); done
  local _processed=0 _u _v
  local -a _adj
  while (( ${#_queue[@]} )); do
    _u="${_queue[0]}"; _queue=("${_queue[@]:1}")
    _processed=$(( _processed + 1 ))
    _adj=()
    [[ -z "${_dependents["${_u}"]:-}" ]] || read -ra _adj <<< "${_dependents["${_u}"]}"
    for _v in "${_adj[@]+"${_adj[@]}"}"; do
      _indeg[_v]=$(( _indeg[_v] - 1 ))
      (( _indeg[_v] == 0 )) && _queue+=("${_v}")
    done
  done
  if (( _processed < n )); then
    local -a _cyc=()
    for (( _k = 0; _k < n; _k++ )); do (( _indeg[_k] > 0 )) && _cyc+=("${_names[_k]}"); done
    error "bootstrap: dependsOn: cycle detected (${_cyc[*]})"
    return 1
  fi

  # ── Run the DAG: launch every entry whose deps are done, up to the cap ──
  local _rcdir; _rcdir=$(mktemp -d) \
    || { error "bootstrap: failed to create scheduler temp dir"; return 1; }
  _BS_INFLIGHT=(); _BS_RCFILES=(); _BS_RUNIDX=()
  unset '_BS_COMPLETED'; declare -gA _BS_COMPLETED=()
  _BS_DONE=0; _BS_OVERALL_RC=0
  local -A _started=()
  local _seq=0

  while (( _BS_DONE < n )); do
    # Launch phase: every not-yet-started entry whose effective deps are all
    # completed, capped at max_parallel concurrent. Stop launching once a failure
    # surfaced — drain the rest, then report (never start work behind a broken dep).
    if (( _BS_OVERALL_RC == 0 )); then
      local _i2
      for (( _i2 = 0; _i2 < n; _i2++ )); do
        # A foreground gate (below) can flip _BS_OVERALL_RC mid-pass; re-check so
        # we never launch an entry positioned behind a just-failed gate in the
        # SAME pass (the background path only surfaces failure on reap, already
        # guarded by the outer `if` next iteration — keep both paths consistent).
        (( _BS_OVERALL_RC == 0 )) || break
        [[ -z "${_started["${_i2}"]:-}" ]] || continue
        (( ${#_BS_INFLIGHT[@]} < max_parallel )) || break
        local _ready=1 _d2
        local -a _dl=()
        [[ -z "${_edeps[_i2]}" ]] || read -ra _dl <<< "${_edeps[_i2]}"
        for _d2 in "${_dl[@]+"${_dl[@]}"}"; do
          [[ -n "${_BS_COMPLETED["${_d2}"]:-}" ]] || { _ready=0; break; }
        done
        (( _ready )) || continue
        # Readiness wait IFF something needs this entry Ready: a dep-target or a
        # wait-gate. A pure leaf passes "" → _apply_one skips wait_ready (the point).
        local _wflag=""
        if (( _istarget[_i2] )) || [[ "${_waits[_i2]}" == "true" ]]; then
          _wflag="wait"
        fi
        _started["${_i2}"]=1

        if [[ "${_waits[_i2]}" == "true" ]]; then
          # wait: true GATE — run it SYNCHRONOUSLY in the FOREGROUND, NOT as a
          # backgrounded subshell and WITHOUT LOK8S_NONINTERACTIVE, so kapply keeps
          # a usable /dev/tty for its interactive immutable/terminating heal prompt
          # (a background job has no controlling tty → kapply::_interactive is
          # false → it can never prompt). This loses NO concurrency: a gate
          # provably runs ALONE — it depends on every entry positionally before it
          # (all therefore already completed AND reaped, so nothing is in flight)
          # and every entry after it depends on the gate (none is launchable until
          # the gate completes). The ( … ) subshell still isolates the
          # KAPPLY_LAST_OUTPUT global, yet — being foreground, not `&` — inherits
          # the terminal. Mark it completed INLINE (same as the reap path) so its
          # dependents become launchable on the next pass; capture rc EXPLICITLY
          # (|| _garc=$?) so an errexit-failing apply can't abort the runner.
          local _garc=0
          ( bootstrap::_apply_one "${_names[_i2]}" "${_dirs[_i2]}" "${kind}" "${provider_name}" \
              "${kubeconfig}" "${_inlines[_i2]}" "${_wflag}" "${_envs[_i2]}" ) || _garc=$?
          (( _garc == 0 )) || _BS_OVERALL_RC=1
          _BS_COMPLETED["${_i2}"]=1
          _BS_DONE=$(( _BS_DONE + 1 ))
          continue
        fi

        _seq=$(( _seq + 1 ))
        local _rcf="${_rcdir}/${_seq}.rc"
        # Non-gate entries fan out as concurrent BACKGROUND subshells: each in its
        # own subshell so KAPPLY_LAST_OUTPUT stays isolated across concurrent
        # applies; LOK8S_NONINTERACTIVE because N backgrounded applies have no
        # shared /dev/tty for kapply's collapsing progress UI / interactive heal
        # prompt (immutable/terminating still fail fast; --force-recreate still
        # heals, it just never prompts). Capture the rc EXPLICITLY (|| _arc=$?) —
        # under errexit a failing _apply_one would abort before `echo $?` runs;
        # _collect_rc treats a missing file as a failure too. Set
        # LOK8S_BOOTSTRAP_PARALLEL=1 for clean one-at-a-time output.
        ( export LOK8S_NONINTERACTIVE=1
          _arc=0
          bootstrap::_apply_one "${_names[_i2]}" "${_dirs[_i2]}" "${kind}" "${provider_name}" \
            "${kubeconfig}" "${_inlines[_i2]}" "${_wflag}" "${_envs[_i2]}" || _arc=$?
          echo "${_arc}" > "${_rcf}" ) &
        _BS_INFLIGHT+=("$!")
        _BS_RCFILES+=("${_rcf}")
        _BS_RUNIDX+=("${_i2}")
      done
    fi

    # Nothing in flight → either everything finished, or a failure halted new
    # launches and we've drained the rest. Either way, stop looping.
    (( ${#_BS_INFLIGHT[@]} )) || break

    bootstrap::_reap_one
  done

  bootstrap::_drain   # safety: never leave an orphan behind
  rm -rf "${_rcdir}"
  return "${_BS_OVERALL_RC}"
}

[[ "${0}" != "${BASH_SOURCE[0]}" && "${ARGSH_SOURCE:-}" != "${BASH_SOURCE[0]}" ]] || main::bootstrap "${@}"
