#!/usr/bin/env argsh
# shellcheck shell=bash disable=SC2034
# vim: set syntax=bash:
# manifest — cluster manifest management
# Lists overlays, reads kubernetes version from spec, generates CAPI resources.

import ^utils/types
import ^utils/verbose

main::manifest() {
  local domain="${domain:-${DOMAIN_NAME:-}}"
  local -a args=(
    'domain|:^~domain'  'Domain to use'
    "${args[@]:-}"
  )
  local -a usage=(
    'list|l'        'List available overlays'
    'addons|a'      'List active addons for the overlay'
    'kubernetes|k'  'Print Kubernetes version from spec'
    'generate|g'    'Generate CAPI resources from lok8s spec'
  )
  :usage "Manage cluster manifests" "${@}"
  "${usage[@]}"
}

manifest::list() {
  :args "List available overlays" "${@}"
  # List from both legacy and new paths
  if [[ -d "${PATH_BASE}/.clusters/overlays" ]]; then
    find "${PATH_BASE}/.clusters/overlays" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort
  fi
  # Also list cluster domains
  if [[ -d "${PATH_CLUSTERS}" ]]; then
    for dir in "${PATH_CLUSTERS}"/*/; do
      [[ -d "${dir}" ]] || continue
      local name
      name=$(basename "${dir}")
      # Skip dot-prefixed (state files)
      [[ "${name}" == .* ]] && continue
      echo "${name}"
    done | sort
  fi
}

manifest::addons() {
  :args "List active addons for the overlay" "${@}"
  local domain="${DOMAIN_NAME:-lok8s.dev}"
  local res_dir="${PATH_CLUSTERS}/${domain}/targets"
  [[ -d "${res_dir}" ]] || { error "No resources found: ${res_dir}"; return 1; }
  find "${res_dir}" -mindepth 1 -maxdepth 1 -type d -printf '%f\n' | sort
}

manifest::kubernetes() {
  :args "Print Kubernetes version from spec" "${@}"
  # Try new CRD-style path first, fall back to legacy flat format
  local domain="${DOMAIN_NAME:-lok8s.dev}"
  local spec_file="${PATH_CLUSTERS}/${domain}/cluster.lok8s.yaml"
  if [[ -f "${spec_file}" ]]; then
    yq -r '.spec.kubernetes.version' "${spec_file}"
    return
  fi

  # Legacy path
  spec_file="${PATH_BASE}/${domain}.lok8s.yaml"
  [[ -f "${spec_file}" ]] || { error "Spec not found: ${spec_file}"; return 1; }
  # Try CRD format first, fall back to flat format
  local version
  version=$(yq -r '.spec.kubernetes.version // .kubernetes.version // ""' "${spec_file}")
  [[ -n "${version}" ]] || { error "Could not read kubernetes version from ${spec_file}"; return 1; }
  echo "${version}"
}

manifest::generate() {
  :args "Generate CAPI resources from lok8s spec" "${@}"
  k8s::capi
}

[[ "${0}" != "${BASH_SOURCE[0]}" && "${ARGSH_SOURCE:-}" != "${BASH_SOURCE[0]}" ]] || main::manifest "${@}"