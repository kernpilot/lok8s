#!/usr/bin/env argsh
# shellcheck shell=bash disable=SC2034
# vim: set syntax=bash:
# crds — generate operator/crds/<kind>.yaml from operator/crds/schema/<kind>.schema.yaml
#
# SINGLE SOURCE OF TRUTH: the schema/ files (a few CRD knobs + the verbatim
# spec/status OpenAPI bodies). The operator/crds/<kind>.yaml files are GENERATED
# — never hand-edit them; edit the schema and run `lo crds generate`.
# `lo crds check` is the CI drift gate. Uses mikefarah yq (the b-pinned .bin/yq).

import ^utils/verbose

CRD_SCHEMA_DIR="${PATH_BASE}/operator/crds/schema"
CRD_OUT_DIR="${PATH_BASE}/operator/crds"
CRD_BANNER="# GENERATED by 'lo crds generate' — DO NOT EDIT. Source: operator/crds/schema/"

main::crds() {
  local -a usage=(
    'generate|g@idempotent' 'Generate operator/crds/*.yaml from schema/*.schema.yaml'
    'check|c@readonly'      'Fail if any generated CRD is stale (drift gate)'
  )
  :usage "Generate operator CRDs from a single schema source" "${@}"
  "${usage[@]}"
}

# Render one schema/<kind>.schema.yaml into a complete CRD on stdout. The spec and
# status bodies are copied verbatim (so x-kubernetes-preserve-unknown-fields,
# pattern, propertyNames, etc. survive); the CRD wrapper is pure boilerplate.
# The three del()s drop ONLY the optional wrapper knobs a kind omits
# (shortNames / printer columns / status). We must NOT use a recursive
# `del(.. | select(. == null))` here: that would also strip legitimate nulls
# inside the verbatim spec/status (e.g. `default: null`, a `null` enum member),
# silently changing validation with no drift signal.
crds::_render() {
  yq eval '{
    "apiVersion": "apiextensions.k8s.io/v1",
    "kind": "CustomResourceDefinition",
    "metadata": {"name": (.plural + "." + .group)},
    "spec": {
      "group": .group,
      "names": {"kind": .kind, "listKind": (.kind + "List"), "plural": .plural,
                "singular": (.kind | downcase), "shortNames": .shortNames},
      "scope": (.scope // "Namespaced"),
      "versions": [{
        "name": .version, "served": true, "storage": true,
        "subresources": {"status": {}},
        "additionalPrinterColumns": .printerColumns,
        "schema": {"openAPIV3Schema": {"type": "object", "required": ["spec"],
                   "properties": {"spec": .spec, "status": .status}}}
      }]
    }
  }
  | del(.spec.names.shortNames | select(. == null))
  | del(.spec.versions[0].additionalPrinterColumns | select(. == null))
  | del(.spec.versions[0].schema.openAPIV3Schema.properties.status | select(. == null))' "$1"
}

# Generate every CRD from its schema.
crds::generate() {
  local schema kind out
  for schema in "${CRD_SCHEMA_DIR}"/*.schema.yaml; do
    [[ -f "${schema}" ]] || continue
    kind=$(yq -r '.kind | downcase' "${schema}")
    out="${CRD_OUT_DIR}/${kind}.yaml"
    { echo "${CRD_BANNER}${kind}.schema.yaml"; crds::_render "${schema}"; } > "${out}"
    echo "  wrote operator/crds/${kind}.yaml"
  done
}

# Drift gate: regenerate into a temp dir and diff against the committed CRDs.
crds::check() {
  local tmp; tmp=$(mktemp -d)
  local schema kind rc=0
  for schema in "${CRD_SCHEMA_DIR}"/*.schema.yaml; do
    [[ -f "${schema}" ]] || continue
    kind=$(yq -r '.kind | downcase' "${schema}")
    { echo "${CRD_BANNER}${kind}.schema.yaml"; crds::_render "${schema}"; } > "${tmp}/${kind}.yaml"
    if ! diff -q "${tmp}/${kind}.yaml" "${CRD_OUT_DIR}/${kind}.yaml" >/dev/null 2>&1; then
      error "  operator/crds/${kind}.yaml is STALE — run 'lo crds generate'"
      rc=1
    fi
  done
  rm -rf "${tmp}"
  (( rc )) || echo "  all CRDs up to date."
  return "${rc}"
}

[[ "${0}" != "${BASH_SOURCE[0]}" && "${ARGSH_SOURCE:-}" != "${BASH_SOURCE[0]}" ]] || main::crds "${@}"
