#!/usr/bin/env bash
set -eu -o pipefail

: "${PATH_BASE:="$(git rev-parse --show-toplevel)"}"

# Local binaries managed by b 
# https://binary.help
: "${PATH_BIN:="${PATH_BASE}/.bin"}"

# .lok8s/ holds the framework: CLI (lo), libs, drivers, providers,
# Tilt extension. Flat tree, all framework-managed.
#   .lok8s/lo            CLI entrypoint
#   .lok8s/libs/         shared bash libraries
#   .lok8s/utils/        utility helpers (verbose, ip, types, ...)
#   .lok8s/drivers/      cluster-architecture drivers (lo/kind, capi, ...)
#   .lok8s/providers/    physical infrastructure providers (hetzner, ...)
#   .lok8s/tilt/         Tilt extension
: "${PATH_LOK8S:="${PATH_BASE}/.lok8s"}"

# clusters/ holds user-defined cluster definitions, one directory per
# FQDN. Each cluster directory contains cluster.lok8s.yaml + targets/ +
# generated artifacts/. Override to point at a non-standard location
# (e.g. a parallel project) without touching the framework.
: "${PATH_CLUSTERS:="${PATH_BASE}/clusters"}"

# Cache directory for the secrets.lok8s.dev/v1/Secret plugin.
# Cache-first determinism: first run generates, subsequent runs reuse.
# To rotate: delete the relevant file from this directory.
: "${PATH_SECRETS:="${PATH_BASE}/.secrets"}"

# Kustomize plugin discovery — exec plugins under .kustomize/<group>/<version>/<kind>/<Kind>.
# Built by `lo plugins build` (Go source under kustomize/).
: "${KUSTOMIZE_PLUGIN_HOME:="${PATH_BASE}/.kustomize"}"

# Default kubeconfig
: "${KUBECONFIG:="${PATH_BASE}/.kubeconfig/secret.local.yaml"}"

# Test discovery for argsh test / argsh MCP. Semicolon-separated dirs
# containing .bats files. argsh also checks PATH_BASE/tests/ but the
# nested unit/ and e2e/ dirs need explicit listing.
: "${PATH_TESTS:="tests/unit;tests/e2e"}"

export PATH_BASE PATH_BIN PATH_LOK8S PATH_CLUSTERS PATH_SECRETS KUSTOMIZE_PLUGIN_HOME KUBECONFIG PATH_TESTS
main() {
  PATH_add "${PATH_BIN}"
  PATH_add "${PATH_LOK8S}"
}

main